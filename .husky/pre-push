# Enforce branch naming before push: type/issue#-slug (issue# optional).
# See CLAUDE.md#branching--commits. `main` is exempt (release/bump pushes).
# `claude` is for automated Claude Code routine PRs (e.g. the blog cross-post),
# which can only push claude/-prefixed branches.
pattern='^(feat|fix|chore|docs|refactor|test|ci|perf|claude)/([0-9]+-)?[a-z0-9]+(-[a-z0-9]+)*$'

invalid=0
while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip branch deletions (local sha is all zeros).
  case "$local_sha" in *[!0]*) ;; *) continue ;; esac
  case "$local_ref" in
    refs/heads/*) branch=${local_ref#refs/heads/} ;;
    *) continue ;;
  esac
  [ "$branch" = "main" ] && continue
  if ! printf '%s' "$branch" | grep -Eq "$pattern"; then
    echo "✗ branch '$branch' is not a valid name" >&2
    invalid=1
  fi
done

if [ "$invalid" -ne 0 ]; then
  echo "" >&2
  echo "Branch names must match: type/issue#-slug  (issue# optional → type/slug)" >&2
  echo "  type ∈ feat|fix|chore|docs|refactor|test|ci|perf|claude" >&2
  echo "  e.g. feat/68-ci-snapshot-refresh · fix/48-icon-colours · claude/blog-some-post" >&2
  echo "Rename with: git branch -m <new-name>   (see CLAUDE.md#branching--commits)" >&2
  exit 1
fi

pnpm typecheck
