---
import type { Project } from '../lib/schemas';
import { langColor } from '../lib/langColors';
import { daysAgo, fmtRelative } from '../lib/format';

interface Props {
  project: Project;
}
const { project } = Astro.props;

const m = project.repo?.match(/github\.com\/([^/]+)\/([^/]+)/);
const owner = m ? `${m[1]}/` : '';
const repoName = m ? m[2]! : project.name;
const href = project.repo ?? project.url ?? undefined;

// data-tags drives client-side filtering on the projects page.
const filterTokens = [...project.tags, project.lang]
  .filter(Boolean)
  .map((t) => t!.toLowerCase())
  .concat(project.pinned ? ['pinned'] : [])
  .join(' ');

// data-updated = whole days since updatedAt, so the sort control can order
// cards. No ISO date → sorts last. The footer shows the derived "2d ago" label.
const updatedDays = project.updatedAt ? daysAgo(project.updatedAt) : 99999;
const updatedLabel = project.updatedAt ? fmtRelative(project.updatedAt) : '';
---

<article
  aria-label={project.name}
  data-project
  data-tags={filterTokens}
  data-updated={updatedDays}
  data-stars={project.stars ?? 0}
  class="flex flex-col rounded-lg border border-ctp-surface0 bg-ctp-mantle p-5 transition-colors duration-150 ease-out hover:border-ctp-surface1"
>
  <div class="flex items-start justify-between gap-2">
    <div class="min-w-0">
      <div class="font-mono text-[11px] text-ctp-overlay2">{owner}</div>
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-[17px] font-semibold text-ctp-teal hover:underline"
      >
        {repoName}
      </a>
    </div>
    {
      project.pinned && (
        <span
          data-testid="pin-badge"
          class="shrink-0 rounded bg-ctp-peach px-1.5 py-0.5 font-mono text-[10px] font-semibold tracking-wide text-ctp-crust uppercase"
        >
          ★ PIN
        </span>
      )
    }
  </div>

  <p class="mt-3 flex-1 text-sm text-ctp-subtext0">{project.description}</p>

  {
    project.tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {project.tags.map((tag) => (
          <span class="rounded bg-ctp-surface0 px-2 py-0.5 font-mono text-[10.5px] text-ctp-subtext1">
            #{tag.toLowerCase()}
          </span>
        ))}
      </div>
    )
  }

  <div
    class="mt-4 flex items-center justify-between border-t border-ctp-surface0 pt-3 font-mono text-[11px] text-ctp-subtext0"
  >
    {
      project.lang && (
        <span class="flex items-center gap-1.5">
          <span class="h-2.5 w-2.5 rounded-[2px]" style={`background:${langColor(project.lang)}`} />
          {project.lang}
        </span>
      )
    }
    <span class="text-ctp-overlay1">
      ★{project.stars ?? 0} · ⑃{project.forks ?? 0}{updatedLabel ? ` · ${updatedLabel}` : ''}
    </span>
  </div>
</article>
