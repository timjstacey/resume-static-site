---
import type { Job } from '../lib/schemas';
import StatusBadge from './StatusBadge.astro';

interface Props {
  job: Job;
}

const { job } = Astro.props;

function fmtDate(iso: string): string {
  const [y, m, d] = iso.split('-').map(Number) as [number, number, number];
  return new Date(y, m - 1, d).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}
---

<div class="flex h-full flex-col rounded-lg border border-ctp-surface1 bg-ctp-mantle p-5">
  <div class="flex items-start justify-between gap-2">
    <div>
      <h2 class="font-semibold text-ctp-text">
        {
          job.url ? (
            <a href={job.url} target="_blank" rel="noopener noreferrer" class="hover:text-ctp-blue">
              {job.company}
            </a>
          ) : (
            job.company
          )
        }
      </h2>
      <p class="text-sm text-ctp-subtext1">{job.role}</p>
    </div>
    <StatusBadge status={job.status} />
  </div>
  <p class="mt-3 text-xs text-ctp-overlay1">Applied {fmtDate(job.applied)}</p>
  {job.notes && <p class="mt-2 text-sm text-ctp-subtext1">{job.notes}</p>}
</div>
