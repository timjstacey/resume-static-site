---
// Section kicker: a 24px accent bar + uppercase mono label. The dominant
// rhythm of the design — every section opens with one.
interface Props {
  color?: string; // Catppuccin accent key, e.g. 'peach' | 'teal' | 'sapphire'
}
const { color = 'peach' } = Astro.props;
---

<div class="inline-flex items-center gap-2.5 mono-caption" style={`color: var(--catppuccin-color-${color})`}>
  <span class="h-px w-6" style={`background: var(--catppuccin-color-${color})`}></span>
  <slot />
</div>
