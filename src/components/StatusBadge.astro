---
import type { JobStatus } from '../lib/schemas';

interface Props {
  status: JobStatus;
}

const { status } = Astro.props;

const statusClass: Record<JobStatus, string> = {
  Applied: 'bg-ctp-blue/10 text-ctp-blue',
  Screening: 'bg-ctp-sapphire/10 text-ctp-sapphire',
  Interviewing: 'bg-ctp-peach/10 text-ctp-peach',
  Offered: 'bg-ctp-green/10 text-ctp-green',
  Rejected: 'bg-ctp-red/10 text-ctp-red',
  Withdrawn: 'bg-ctp-overlay2/10 text-ctp-overlay2',
  Ghosted: 'bg-ctp-mauve/10 text-ctp-mauve',
};
---

<span class={`inline-flex shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium ${statusClass[status]}`}>
  {status}
</span>
