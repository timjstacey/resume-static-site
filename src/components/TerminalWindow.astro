---
// Terminal/code window: chrome bar (traffic lights + file path + right meta)
// over a body slot. Used by the blog featured preview, the home whoami card,
// and the testing code window. Pass a `status` slot to replace the right-hand
// meta text with a live indicator.
interface Props {
  path: string;
  meta?: string;
  class?: string;
}
const { path, meta = 'UTF-8 · markdown', class: extra = '' } = Astro.props;
const hasStatus = Astro.slots.has('status');
---

<div
  class:list={[
    'overflow-hidden rounded-[10px] border border-ctp-surface1 bg-ctp-mantle shadow-[0_12px_40px_rgba(0,0,0,0.3)]',
    extra,
  ]}
>
  <div class="flex items-center gap-3 border-b border-ctp-surface1 bg-ctp-surface0 px-4 py-2.5">
    <span class="flex gap-2" aria-hidden="true">
      <span class="h-[11px] w-[11px] rounded-full bg-ctp-red"></span>
      <span class="h-[11px] w-[11px] rounded-full bg-ctp-yellow"></span>
      <span class="h-[11px] w-[11px] rounded-full bg-ctp-green"></span>
    </span>
    <span class="truncate font-mono text-xs text-ctp-subtext0" data-testid="terminal-path">{path}</span>
    <span class="ml-auto font-mono text-[11px] text-ctp-overlay1">
      {hasStatus ? <slot name="status" /> : meta}
    </span>
  </div>
  <div class="p-5 font-mono text-[13.5px] leading-[1.75]">
    <slot />
  </div>
</div>
