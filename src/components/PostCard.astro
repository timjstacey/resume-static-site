---
import Card from './Card.astro';

// Blog post teaser card with a coloured top accent. Used by the home "From the
// blog" row and the blog index.
interface Props {
  title: string;
  tag: string;
  date: string;
  excerpt: string;
  readMins: number;
  slug: string;
  accent?: string; // Catppuccin accent key for the top border
}
const { title, tag, date, excerpt, readMins, slug, accent = 'peach' } = Astro.props;
---

<Card accent={accent} class="flex flex-col p-6">
  <div class="flex items-center gap-3 font-mono text-[11px] text-ctp-overlay2">
    <span style={`color: var(--color-ctp-${accent})`}>{tag}</span>
    <span>·</span>
    <span>{date}</span>
  </div>
  <h3 class="mt-3 font-display text-2xl font-semibold tracking-[-0.02em] text-ctp-text">
    <a href={`/blog/${slug}`} class="hover:text-ctp-peach">{title}</a>
  </h3>
  <p class="mt-2 text-sm text-ctp-subtext0">{excerpt}</p>
  <div
    class="mt-4 flex items-center justify-between border-t border-dashed border-ctp-surface0 pt-3 font-mono text-[11px] text-ctp-overlay1"
  >
    <span>~{readMins}min</span>
    <a href={`/blog/${slug}`} class="text-ctp-peach hover:underline">cat post.md →</a>
  </div>
</Card>
