---
import { isActivePath, NAV_ITEMS } from '../lib/nav';

const currentPath = Astro.url.pathname;

const links = NAV_ITEMS;
---

<nav class="border-b border-ctp-surface1 bg-ctp-mantle">
  <div class="mx-auto flex max-w-4xl items-center gap-6 px-4 py-3">
    <span class="font-semibold text-ctp-lavender">Tim Stacey</span>

    <!-- Desktop nav links -->
    <ul class="flex gap-4 max-[425px]:hidden">
      {
        links.map(({ href, label }) => {
          const isActive = isActivePath(href, currentPath);
          return (
            <li>
              <a
                href={href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'text-sm transition-colors',
                  isActive ? 'font-medium text-ctp-text' : 'text-ctp-subtext0 hover:text-ctp-text',
                ]}
              >
                {label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="ml-auto flex items-center gap-3">
      <slot />

      <!-- Hamburger button: mobile only -->
      <button
        id="nav-toggle"
        class="hidden items-center justify-center text-ctp-subtext0 hover:text-ctp-text focus:outline-none max-[425px]:flex"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <svg
          id="nav-icon-open"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="nav-icon-close"
          class="hidden h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer: CSS hides it at desktop regardless of JS state -->
  <div id="nav-mobile" class="hidden border-t border-ctp-surface1 min-[426px]:hidden">
    <ul class="mx-auto flex max-w-4xl flex-col px-4 py-2">
      {
        links.map(({ href, label }) => {
          const isActive = isActivePath(href, currentPath);
          return (
            <li>
              <a
                href={href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'block py-2 text-sm transition-colors',
                  isActive ? 'font-medium text-ctp-text' : 'text-ctp-subtext0 hover:text-ctp-text',
                ]}
              >
                {label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>

<script is:inline>
  (function () {
    const toggle = document.getElementById('nav-toggle');
    const drawer = document.getElementById('nav-mobile');
    const iconOpen = document.getElementById('nav-icon-open');
    const iconClose = document.getElementById('nav-icon-close');

    if (!toggle || !drawer || !iconOpen || !iconClose) return;

    function isOpen() {
      return !drawer.classList.contains('hidden');
    }

    function focusables() {
      return Array.from(drawer.querySelectorAll('a[href], button:not([disabled])'));
    }

    function openDrawer() {
      drawer.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      const first = focusables()[0];
      if (first) first.focus();
    }

    function closeDrawer(opts) {
      drawer.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      if (opts && opts.returnFocus) toggle.focus();
    }

    toggle.addEventListener('click', function () {
      if (isOpen()) closeDrawer();
      else openDrawer();
    });

    document.addEventListener('keydown', function (e) {
      if (!isOpen()) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        closeDrawer({ returnFocus: true });
        return;
      }
      if (e.key === 'Tab') {
        const items = focusables();
        if (items.length === 0) return;
        const first = items[0];
        const last = items[items.length - 1];
        const active = document.activeElement;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        } else if (!drawer.contains(active)) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    document.addEventListener('click', function (e) {
      if (!isOpen()) return;
      const target = e.target;
      if (drawer.contains(target) || toggle.contains(target)) return;
      closeDrawer();
    });
  })();
</script>
