---
import { isActivePath, NAV_ITEMS } from '../lib/nav';

const currentPath = Astro.url.pathname;
const links = NAV_ITEMS;

// Breadcrumb: home → "~/", any other route → "~/<segment>".
const trimmed = currentPath.replace(/\/$/, '');
const crumb = trimmed === '' ? '~/' : `~${trimmed}`;
---

<nav aria-label="Primary" class="border-b border-ctp-surface0 bg-ctp-mantle">
  <div class="mx-auto flex max-w-[1440px] items-stretch">
    <!-- Brand block -->
    <a
      href="/"
      data-testid="nav-brand"
      class="flex w-[180px] min-w-0 items-center gap-3.5 border-r border-ctp-surface0 px-5 py-5 lg:w-[280px] lg:px-7"
    >
      <span
        class="flex h-11 w-11 shrink-0 items-center justify-center rounded-[10px] bg-ctp-peach font-display text-lg font-bold tracking-[-0.02em] text-ctp-crust"
      >
        TS
      </span>
      <span class="min-w-0 leading-none">
        <span class="block font-display text-base font-semibold tracking-[-0.01em] text-ctp-text">tim</span>
        <span
          class="mt-1 block truncate font-mono text-[11px] tracking-[0.04em] text-ctp-overlay1"
          aria-hidden="true"
          title={crumb}>{crumb}</span
        >
      </span>
    </a>

    <!-- Centre links: desktop -->
    <div class="hidden flex-1 items-stretch lg:flex">
      {
        links.map(({ href, label }) => {
          const isActive = isActivePath(href, currentPath);
          return (
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'flex items-center gap-2 border-r border-b-2 border-ctp-surface0 px-6 font-mono text-[13px] tracking-[0.02em] transition-colors duration-150 ease-out',
                isActive
                  ? 'border-b-ctp-peach bg-ctp-surface0 text-ctp-peach'
                  : 'border-b-transparent text-ctp-subtext0 hover:text-ctp-text',
              ]}
            >
              {isActive && <span aria-hidden="true">▸</span>}
              {label.toLowerCase()}
            </a>
          );
        })
      }
    </div>

    <!-- Right block -->
    <div
      class="ml-auto flex items-center gap-4 px-5 font-mono text-xs text-ctp-subtext0 lg:ml-0 lg:border-l lg:border-ctp-surface0 lg:px-7"
    >
      <slot />

      <!-- Hamburger: mobile only -->
      <button
        id="nav-toggle"
        class="flex items-center justify-center text-ctp-subtext0 hover:text-ctp-text lg:hidden"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <svg
          id="nav-icon-open"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="nav-icon-close"
          class="hidden h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="nav-mobile" class="hidden border-t border-ctp-surface0 lg:hidden">
    <ul class="flex flex-col px-5 py-2">
      {
        links.map(({ href, label }) => {
          const isActive = isActivePath(href, currentPath);
          return (
            <li>
              <a
                href={href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'block py-2 font-mono text-sm transition-colors',
                  isActive ? 'text-ctp-peach' : 'text-ctp-subtext0 hover:text-ctp-text',
                ]}
              >
                {label.toLowerCase()}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>

<script>
  // DOM glue for the mobile drawer. The pure focus-trap rule (which item Tab
  // should land on) lives in lib/nav.ts (trapFocusTarget) and is unit-tested.
  import { trapFocusTarget } from '../lib/nav';

  const toggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('nav-mobile');
  const iconOpen = document.getElementById('nav-icon-open');
  const iconClose = document.getElementById('nav-icon-close');

  if (toggle && drawer && iconOpen && iconClose) {
    const isOpen = () => !drawer.classList.contains('hidden');
    const focusables = () => Array.from(drawer.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'));

    const openDrawer = () => {
      drawer.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      focusables()[0]?.focus();
    };

    const closeDrawer = (opts?: { returnFocus?: boolean }) => {
      drawer.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      if (opts?.returnFocus) toggle.focus();
    };

    toggle.addEventListener('click', () => (isOpen() ? closeDrawer() : openDrawer()));

    document.addEventListener('keydown', (e) => {
      if (!isOpen()) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        closeDrawer({ returnFocus: true });
        return;
      }
      if (e.key === 'Tab') {
        const items = focusables();
        const activeIndex = items.indexOf(document.activeElement as HTMLElement);
        const target = trapFocusTarget(items.length, activeIndex, e.shiftKey);
        if (target !== null) {
          e.preventDefault();
          items[target]!.focus();
        }
      }
    });

    document.addEventListener('click', (e) => {
      if (!isOpen()) return;
      const target = e.target as Node;
      if (drawer.contains(target) || toggle.contains(target)) return;
      closeDrawer();
    });
  }
</script>
