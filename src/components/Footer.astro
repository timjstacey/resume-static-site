---
import pkg from '../../package.json';
import { TEST_STATS } from '../lib/testStats';
import { getCiSnapshot } from '../lib/data';

const ci = getCiSnapshot();
const v = (dep: string) => (pkg.dependencies as Record<string, string>)[dep]?.replace(/^[\^~]/, '');
const astroV = v('astro')?.split('.').slice(0, 2).join('.');
const tailwindV = v('tailwindcss')?.split('.').slice(0, 2).join('.');
const ctpV = v('@catppuccin/tailwindcss');
---

<footer class="mt-20 border-t border-ctp-surface0 bg-ctp-mantle">
  <div
    class="mx-auto grid max-w-[1440px] grid-cols-2 gap-8 px-6 py-8 font-mono text-xs text-ctp-subtext0 sm:px-14 md:grid-cols-4"
  >
    <div>
      <div class="mb-2 mono-caption text-ctp-overlay2">[ build ]</div>
      <div class="text-ctp-text">astro {astroV} · tailwind {tailwindV}</div>
      <div>catppuccin v{ctpV}</div>
    </div>
    <div>
      <div class="mb-2 mono-caption text-ctp-overlay2">[ ci ]</div>
      <div data-ci-status class:list={['stat-skeleton', ci.passing ? 'text-ctp-green' : 'text-ctp-red']}>
        ● <span data-ci-word>{ci.passing ? 'green' : 'failing'}</span> · <span data-ci-branch>{ci.branch}</span>
      </div>
      <div>last deploy <span data-ci-deploy class="stat-skeleton">{ci.lastDeployAgo}</span></div>
    </div>
    <div>
      <div class="mb-2 mono-caption text-ctp-overlay2">[ tests ]</div>
      <div class="text-ctp-text">{TEST_STATS.unit} unit · {TEST_STATS.e2e} e2e</div>
      <div>{TEST_STATS.engines} engines</div>
    </div>
    <div class="md:text-right">
      <div class="mb-2 mono-caption text-ctp-overlay2">[ © 2026 ]</div>
      <div class="text-ctp-text">tim stacey</div>
      <div>v{pkg.version}</div>
    </div>
  </div>
</footer>

<script>
  import '../scripts/footer-ci';
</script>
