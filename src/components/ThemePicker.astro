---
import { FLAVORS, THEME_TRIGGER_LABEL } from '../lib/themes';

const flavors = FLAVORS;
---

<div class="relative flex items-center">
  <button
    id="theme-trigger"
    aria-label={THEME_TRIGGER_LABEL}
    aria-haspopup="menu"
    aria-expanded="false"
    title={THEME_TRIGGER_LABEL}
    class="flex cursor-pointer items-center gap-2 font-mono text-xs text-ctp-subtext0 transition-colors hover:text-ctp-text"
  >
    <span id="theme-swatch" class="h-2.5 w-2.5 rounded-[2px] border border-ctp-text/20 bg-ctp-peach" aria-hidden="true"
    ></span>
    <span id="theme-label">mocha</span>
  </button>

  <div
    id="theme-dropdown"
    role="menu"
    aria-label={THEME_TRIGGER_LABEL}
    class="absolute top-8 right-0 z-50 hidden min-w-[140px] flex-col gap-1 rounded-lg border border-ctp-surface1 bg-ctp-mantle p-2 shadow-lg"
  >
    {
      flavors.map(({ id, label, bg }) => (
        <button
          data-flavor={id}
          role="menuitemradio"
          aria-label={`${label} theme`}
          aria-checked="false"
          tabindex="-1"
          class="flex cursor-pointer items-center gap-2 rounded px-2 py-1 text-sm text-ctp-subtext0 transition-colors hover:text-ctp-text"
        >
          <span class="h-4 w-4 shrink-0 rounded-full border border-ctp-surface1" style={`background-color: ${bg};`} />
          {label}
        </button>
      ))
    }
  </div>
</div>

<style>
  button[aria-checked='true'] span:first-child {
    box-shadow:
      0 0 0 2px var(--catppuccin-color-mantle),
      0 0 0 4px var(--catppuccin-color-peach);
  }
</style>

<script>
  // DOM glue for the flavour menu. Pure rules live in lib/themes.ts and are
  // unit-tested: flavorFromClasses (which flavour is on <html>), rovingIndex
  // (arrow/Home/End focus wrap). FLAVOR_IDS is the single source of valid ids.
  import { FLAVOR_IDS, flavorFromClasses, rovingIndex, type FlavorId } from '../lib/themes';

  function applyFlavor(flavor: FlavorId) {
    for (const f of FLAVOR_IDS) document.documentElement.classList.remove(f);
    document.documentElement.classList.add(flavor);
    try {
      localStorage.setItem('ctp-flavor', flavor);
    } catch {
      /* storage unavailable */
    }
    syncPicker(flavor);
    syncTrigger(flavor);
    closeDropdown({ returnFocus: true });
  }

  function syncTrigger(flavor: string) {
    const label = document.getElementById('theme-label');
    if (label) label.textContent = flavor;
  }

  function syncPicker(flavor: string) {
    for (const btn of items()) {
      btn.setAttribute('aria-checked', btn.dataset.flavor === flavor ? 'true' : 'false');
    }
  }

  function activeFlavor(): FlavorId {
    return flavorFromClasses(document.documentElement.classList);
  }

  function items(): HTMLElement[] {
    return Array.from(document.querySelectorAll<HTMLElement>('#theme-dropdown [data-flavor]'));
  }

  function openDropdown() {
    const dropdown = document.getElementById('theme-dropdown');
    const trigger = document.getElementById('theme-trigger');
    if (!dropdown || !trigger) return;
    dropdown.classList.remove('hidden');
    dropdown.classList.add('flex');
    trigger.setAttribute('aria-expanded', 'true');
    const list = items();
    const current = list.find((b) => b.getAttribute('aria-checked') === 'true');
    (current ?? list[0])?.focus();
  }

  function closeDropdown(opts?: { returnFocus?: boolean }) {
    const dropdown = document.getElementById('theme-dropdown');
    const trigger = document.getElementById('theme-trigger');
    if (!dropdown || !trigger) return;
    dropdown.classList.add('hidden');
    dropdown.classList.remove('flex');
    trigger.setAttribute('aria-expanded', 'false');
    if (opts?.returnFocus) trigger.focus();
  }

  function isOpen() {
    const d = document.getElementById('theme-dropdown');
    return !!d && !d.classList.contains('hidden');
  }

  function initPicker() {
    const flavor = activeFlavor();
    syncPicker(flavor);
    syncTrigger(flavor);

    const trigger = document.getElementById('theme-trigger');
    const dropdown = document.getElementById('theme-dropdown');
    if (!trigger || !dropdown) return;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      if (isOpen()) closeDropdown();
      else openDropdown();
    });

    for (const btn of items()) {
      btn.addEventListener('click', () => {
        if (btn.dataset.flavor) applyFlavor(btn.dataset.flavor as FlavorId);
      });
    }

    dropdown.addEventListener('keydown', (e) => {
      const list = items();
      const next = rovingIndex(list.length, list.indexOf(document.activeElement as HTMLElement), e.key);
      if (next !== null) {
        e.preventDefault();
        list[next]!.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (isOpen() && !dropdown.contains(e.target as Node) && e.target !== trigger) closeDropdown();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) closeDropdown({ returnFocus: true });
    });

    window.addEventListener('resize', () => {
      if (isOpen()) closeDropdown();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPicker);
  } else {
    initPicker();
  }
</script>
