---
import { FLAVORS, THEME_TRIGGER_LABEL } from '../lib/themes';

const flavors = FLAVORS;
---

<div class="relative flex items-center">
  <button
    id="theme-trigger"
    aria-label={THEME_TRIGGER_LABEL}
    aria-haspopup="menu"
    aria-expanded="false"
    title={THEME_TRIGGER_LABEL}
    class="flex cursor-pointer items-center gap-2 font-mono text-xs text-ctp-subtext0 transition-colors hover:text-ctp-text"
  >
    <span id="theme-swatch" class="h-2.5 w-2.5 rounded-[2px] border border-ctp-text/20 bg-ctp-peach" aria-hidden="true"
    ></span>
    <span id="theme-label">mocha</span>
  </button>

  <div
    id="theme-dropdown"
    role="menu"
    aria-label={THEME_TRIGGER_LABEL}
    class="absolute top-8 right-0 z-50 hidden min-w-[140px] flex-col gap-1 rounded-lg border border-ctp-surface1 bg-ctp-mantle p-2 shadow-lg"
  >
    {
      flavors.map(({ id, label, bg }) => (
        <button
          data-flavor={id}
          role="menuitemradio"
          aria-checked="false"
          tabindex="-1"
          class="flex cursor-pointer items-center gap-2 rounded px-2 py-1 text-sm text-ctp-subtext0 transition-colors hover:text-ctp-text"
        >
          <span class="h-4 w-4 shrink-0 rounded-full border border-ctp-surface1" style={`background-color: ${bg};`} />
          {label}
        </button>
      ))
    }
  </div>
</div>

<style>
  button[aria-checked='true'] span:first-child {
    box-shadow:
      0 0 0 2px var(--color-ctp-mantle),
      0 0 0 4px var(--color-ctp-peach);
  }
</style>

<script is:inline>
  const VALID = ['latte', 'frappe', 'macchiato', 'mocha'];

  function applyFlavor(flavor) {
    VALID.forEach(function (f) {
      document.documentElement.classList.remove(f);
    });
    document.documentElement.classList.add(flavor);
    try {
      localStorage.setItem('ctp-flavor', flavor);
    } catch {}
    syncPicker(flavor);
    syncTrigger(flavor);
    closeDropdown({ returnFocus: true });
  }

  function syncTrigger(flavor) {
    const label = document.getElementById('theme-label');
    if (label) label.textContent = flavor;
  }

  function syncPicker(flavor) {
    document.querySelectorAll('[data-flavor]').forEach(function (btn) {
      btn.setAttribute('aria-checked', btn.dataset.flavor === flavor ? 'true' : 'false');
    });
  }

  function activeFlavor() {
    return (
      VALID.find(function (f) {
        return document.documentElement.classList.contains(f);
      }) || 'mocha'
    );
  }

  function items() {
    return Array.from(document.querySelectorAll('#theme-dropdown [data-flavor]'));
  }

  function openDropdown() {
    const dropdown = document.getElementById('theme-dropdown');
    const trigger = document.getElementById('theme-trigger');
    if (!dropdown || !trigger) return;
    dropdown.classList.remove('hidden');
    dropdown.classList.add('flex');
    trigger.setAttribute('aria-expanded', 'true');
    const list = items();
    const current = list.find(function (b) {
      return b.getAttribute('aria-checked') === 'true';
    });
    (current || list[0]).focus();
  }

  function closeDropdown(opts) {
    const dropdown = document.getElementById('theme-dropdown');
    const trigger = document.getElementById('theme-trigger');
    if (!dropdown || !trigger) return;
    dropdown.classList.add('hidden');
    dropdown.classList.remove('flex');
    trigger.setAttribute('aria-expanded', 'false');
    if (opts && opts.returnFocus) trigger.focus();
  }

  function isOpen() {
    const d = document.getElementById('theme-dropdown');
    return d && !d.classList.contains('hidden');
  }

  function initPicker() {
    const flavor = activeFlavor();
    syncPicker(flavor);
    syncTrigger(flavor);

    const trigger = document.getElementById('theme-trigger');
    const dropdown = document.getElementById('theme-dropdown');
    if (!trigger || !dropdown) return;

    trigger.addEventListener('click', function (e) {
      e.stopPropagation();
      if (isOpen()) closeDropdown();
      else openDropdown();
    });

    items().forEach(function (btn) {
      btn.addEventListener('click', function () {
        applyFlavor(btn.dataset.flavor);
      });
    });

    dropdown.addEventListener('keydown', function (e) {
      const list = items();
      const idx = list.indexOf(document.activeElement);
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        list[(idx + 1) % list.length].focus();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        list[(idx - 1 + list.length) % list.length].focus();
      } else if (e.key === 'Home') {
        e.preventDefault();
        list[0].focus();
      } else if (e.key === 'End') {
        e.preventDefault();
        list[list.length - 1].focus();
      }
    });

    document.addEventListener('click', function (e) {
      if (isOpen() && !dropdown.contains(e.target) && e.target !== trigger) closeDropdown();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen()) closeDropdown({ returnFocus: true });
    });

    window.addEventListener('resize', function () {
      if (isOpen()) closeDropdown();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPicker);
  } else {
    initPicker();
  }
</script>
