---
import Base from '../layouts/Base.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import StatStrip from '../components/StatStrip.astro';
import StatCard from '../components/StatCard.astro';
import PostCard from '../components/PostCard.astro';
import { getResume, getProjects, getJobs } from '../lib/data';
import { getPosts } from '../lib/posts';
import { fmtYM } from '../lib/format';
import { activePipeline, yearsOfExp } from '../lib/stats';
import { TEST_STATS } from '../lib/testStats';

const resume = getResume();
const projects = getProjects();
const jobs = getJobs();
const posts = (await getPosts()).slice(0, 3);

const years = yearsOfExp(resume.experience);
const pipeline = activePipeline(jobs);
const current = resume.experience[0];

const fmtDate = (d: Date) => d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
const postAccents = ['peach', 'teal', 'mauve'];

const meta = current
  ? [
      ['tenure', `${fmtYM(current.start)} – now`],
      ['team', 'lead of 3 QEs'],
      ['stack', 'Playwright · WDIO'],
      ['cadence', 'ships in hours'],
    ]
  : [];
---

<Base title="Home" description={`${resume.name} · ${resume.tagline}`}>
  <!-- HERO -->
  <section
    class="border-b border-ctp-surface0 px-14 pt-16 pb-20"
    style="background: radial-gradient(ellipse 800px 400px at 80% 20%, color-mix(in srgb, var(--catppuccin-color-peach) 7%, transparent), transparent 60%), var(--catppuccin-color-crust)"
  >
    <div class="grid items-start gap-16 lg:grid-cols-[1.4fr_0.9fr]">
      <div>
        <SectionLabel>// intro.tsx</SectionLabel>
        <h1
          class="mt-7 font-display text-6xl leading-[0.92] font-bold tracking-[-0.04em] text-ctp-text md:text-[124px]"
        >
          Lead QE.<br />
          <span class="text-ctp-peach">Ship</span>
          <span class="text-ctp-overlay1">in</span>
          <span class="text-ctp-teal">hours.</span>
        </h1>
        <p class="mt-9 max-w-2xl text-xl leading-relaxed text-ctp-subtext1">
          I build the test infrastructure that takes a team's release cycle from days to hours: strict types, lean UI
          E2E, contract checks at every seam.
        </p>
        <div class="mt-9 flex flex-wrap gap-3">
          <Button variant="primary" href="/resume">▸ cat resume.tex</Button>
          {
            resume.contact.github && (
              <Button variant="ghost" href={resume.contact.github}>
                github ↗
              </Button>
            )
          }
          {
            resume.contact.linkedin && (
              <Button variant="ghost" href={resume.contact.linkedin}>
                linkedin ↗
              </Button>
            )
          }
        </div>
      </div>

      <!-- availability.json -->
      <Card class="p-7">
        <div class="flex items-center justify-between">
          <span class="mono-caption text-ctp-overlay2">availability.json</span>
          <span class="flex items-center gap-2 font-mono text-[11px] text-ctp-green">
            <span class="h-2 w-2 rounded-full bg-ctp-green shadow-[0_0_8px_var(--catppuccin-color-green)]"></span>OPEN
          </span>
        </div>
        <div class="mt-6 font-display text-[56px] leading-none font-bold tracking-[-0.03em] text-ctp-peach">13 Jun</div>
        <div class="mt-2 font-mono text-sm text-ctp-subtext1">2026 onward</div>
        <div class="my-6 border-t border-dashed border-ctp-surface1"></div>
        <dl class="grid grid-cols-2 gap-4 font-mono text-[12.5px]">
          <div><dt class="text-ctp-overlay2">type</dt><dd class="mt-1 text-ctp-text">perm · contract</dd></div>
          <div><dt class="text-ctp-overlay2">location</dt><dd class="mt-1 text-ctp-text">remote · worldwide</dd></div>
          <div><dt class="text-ctp-overlay2">notice</dt><dd class="mt-1 text-ctp-text">available now</dd></div>
          <div>
            <dt class="text-ctp-overlay2">contact</dt><dd class="mt-1 text-ctp-teal">
              {resume.contact.email ?? 'github ↗'}
            </dd>
          </div>
        </dl>
      </Card>
    </div>
  </section>

  <!-- STATS -->
  <StatStrip class="border-b border-ctp-surface0">
    <StatCard index="00" value={years} label="Years experience" />
    <StatCard index="01" value={projects.length} label="Projects" alt />
    <StatCard index="02" value={jobs.length} label="Roles applied for" />
    <StatCard index="03" value={pipeline} label="Active pipeline" alt />
  </StatStrip>

  <!-- ABOUT + CURRENT ROLE -->
  <section class="grid gap-14 px-14 pt-18 lg:grid-cols-[1.4fr_1fr]">
    <div>
      <SectionLabel>// about.md</SectionLabel>
      {resume.bio && <p class="mt-6 text-lg leading-relaxed text-ctp-subtext1">{resume.bio}</p>}
    </div>
    <TerminalWindow path="$ yq '.experience[0]' resume.yml">
      <span slot="status" class="text-ctp-green">● live</span>
      <div class="font-display text-3xl font-bold tracking-[-0.02em] text-ctp-text">{current?.role}</div>
      <div class="mt-1 text-ctp-teal">@ {current?.company.toLowerCase().replace(/[^a-z0-9]+/g, '-')}</div>
      <dl class="mt-5 grid grid-cols-2 gap-4 text-[13px]">
        {
          meta.map(([k, v]) => (
            <div>
              <dt class="text-ctp-overlay1">{k}</dt>
              <dd class="mt-0.5 text-ctp-subtext1">{v}</dd>
            </div>
          ))
        }
      </dl>
    </TerminalWindow>
  </section>

  <!-- WRITING (shown when posts exist) -->
  {
    posts.length > 0 && (
      <section class="px-14 pt-22">
        <div class="flex items-end justify-between">
          <div>
            <SectionLabel color="teal">// writing</SectionLabel>
            <h2 class="mt-4 font-display text-4xl font-bold tracking-[-0.025em] text-ctp-text">
              From the blog<span class="text-ctp-peach">.</span>
            </h2>
          </div>
          <Button variant="ghost" href="/blog">
            all posts →
          </Button>
        </div>
        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {posts.map((post, i) => (
            <PostCard
              title={post.data.title}
              tag={post.data.tag}
              date={fmtDate(post.data.date)}
              excerpt={post.data.excerpt}
              readMins={post.data.readMins}
              slug={post.id}
              accent={postAccents[i % postAccents.length]!}
            />
          ))}
        </div>
      </section>
    )
  }

  <!-- TESTING TEASER -->
  <section class="px-14 pt-18 pb-4">
    <TerminalWindow path="$ pnpm test && pnpm test:e2e">
      <span slot="status" class="text-ctp-green">● passing</span>
      <div class="grid items-center gap-8 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
        <p class="font-display text-[28px] leading-tight font-bold tracking-[-0.02em] text-ctp-text">
          This site runs the tests it ships.
        </p>
        <div>
          <div class="mono-caption text-ctp-overlay1">unit</div><div
            class="mt-1 font-display text-4xl font-bold text-ctp-green"
            data-testid="teaser-unit"
          >
            {TEST_STATS.unit}
          </div>
        </div>
        <div>
          <div class="mono-caption text-ctp-overlay1">e2e</div><div
            class="mt-1 font-display text-4xl font-bold text-ctp-sapphire"
            data-testid="teaser-e2e"
          >
            {TEST_STATS.e2e}
          </div>
        </div>
        <div>
          <div class="mono-caption text-ctp-overlay1">engines</div><div
            class="mt-1 font-display text-4xl font-bold text-ctp-mauve"
          >
            {TEST_STATS.engines}
          </div>
        </div>
      </div>
    </TerminalWindow>
  </section>
</Base>
