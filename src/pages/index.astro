---
import Base from '../layouts/Base.astro';
import { getResume, getProjects, getJobs } from '../lib/data';

const resume = getResume();
const projects = getProjects();
const jobs = getJobs();

const activeStatuses = new Set(['Applied', 'Screening', 'Interviewing', 'Offered']);
const activePipeline = jobs.filter((j) => activeStatuses.has(j.status)).length;

const earliestStart = resume.experience.map((e) => new Date(e.start + '-01')).reduce((a, b) => (a < b ? a : b));
const yearsOfExp = Math.floor((Date.now() - earliestStart.getTime()) / (365.25 * 24 * 60 * 60 * 1000));

const currentRole = resume.experience[0]!;
const formatYearMonth = (ym: string) =>
  new Date(+ym.slice(0, 4), +ym.slice(5, 7) - 1).toLocaleDateString('en-AU', {
    month: 'short',
    year: 'numeric',
  });
---

<Base title="Home" description={`${resume.name} — ${resume.tagline}`}>
  <section class="py-12 text-center">
    <h1 class="text-5xl font-bold text-ctp-text">{resume.name}</h1>
    <p class="mt-3 text-xl text-ctp-subtext1">{resume.tagline}</p>
    <div class="mt-6 flex justify-center gap-6">
      {
        resume.contact.github && (
          <a
            href={resume.contact.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-ctp-subtext1 transition-colors hover:text-ctp-blue"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
            </svg>
            GitHub
          </a>
        )
      }
      {
        resume.contact.linkedin && (
          <a
            href={resume.contact.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-ctp-subtext1 transition-colors hover:text-ctp-blue"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
            LinkedIn
          </a>
        )
      }
    </div>
  </section>

  {
    resume.bio && (
      <section class="mb-12">
        <h2 class="mb-3 text-xl font-semibold text-ctp-text">About</h2>
        <p class="leading-relaxed text-ctp-subtext1">{resume.bio}</p>
      </section>
    )
  }

  <section class="mb-12 grid grid-cols-2 gap-4 sm:grid-cols-4">
    <div class="rounded-lg border border-ctp-surface1 bg-ctp-mantle p-6 text-center">
      <p class="text-3xl font-bold text-ctp-mauve">{yearsOfExp}</p>
      <p class="mt-1 text-sm text-ctp-subtext1">Years experience</p>
    </div>
    <div class="rounded-lg border border-ctp-surface1 bg-ctp-mantle p-6 text-center">
      <p class="text-3xl font-bold text-ctp-blue">{projects.length}</p>
      <p class="mt-1 text-sm text-ctp-subtext1">Projects</p>
    </div>
    <div class="rounded-lg border border-ctp-surface1 bg-ctp-mantle p-6 text-center">
      <p class="text-3xl font-bold text-ctp-green">{jobs.length}</p>
      <p class="mt-1 text-sm text-ctp-subtext1">Jobs applied</p>
    </div>
    <div class="rounded-lg border border-ctp-surface1 bg-ctp-mantle p-6 text-center">
      <p class="text-3xl font-bold text-ctp-peach">{activePipeline}</p>
      <p class="mt-1 text-sm text-ctp-subtext1">Active pipeline</p>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-3 text-xl font-semibold text-ctp-text">Current Role</h2>
    <div class="rounded-lg border border-ctp-surface1 bg-ctp-mantle p-6">
      <p class="font-semibold text-ctp-text">{currentRole.role}</p>
      <p class="mt-1 text-sm text-ctp-subtext1">
        {currentRole.company} &middot; {formatYearMonth(currentRole.start)} &ndash;
        {currentRole.end === 'present' ? 'Present' : formatYearMonth(currentRole.end)}
      </p>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-4 text-xl font-semibold text-ctp-text">Skills</h2>
    <div class="flex flex-col gap-5">
      {
        resume.skills.map((group) => (
          <div>
            <p class="mb-2 text-sm text-ctp-subtext1">{group.category}</p>
            <div class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="rounded-full bg-ctp-surface0 px-3 py-1 text-sm text-ctp-text">{item}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="grid grid-cols-1 gap-4 sm:grid-cols-3">
    <a
      href="/resume"
      class="block rounded-lg border border-ctp-surface1 bg-ctp-mantle p-6 transition-colors hover:bg-ctp-surface0"
    >
      <h3 class="font-semibold text-ctp-text">Resume</h3>
      <p class="mt-1 text-sm text-ctp-subtext1">Full work history and skills</p>
    </a>
    <a
      href="/projects"
      class="block rounded-lg border border-ctp-surface1 bg-ctp-mantle p-6 transition-colors hover:bg-ctp-surface0"
    >
      <h3 class="font-semibold text-ctp-text">Projects</h3>
      <p class="mt-1 text-sm text-ctp-subtext1">Side projects and open source</p>
    </a>
    <a
      href="/jobs"
      class="block rounded-lg border border-ctp-surface1 bg-ctp-mantle p-6 transition-colors hover:bg-ctp-surface0"
    >
      <h3 class="font-semibold text-ctp-text">Job Board</h3>
      <p class="mt-1 text-sm text-ctp-subtext1">Application tracker and pipeline</p>
    </a>
  </section>
</Base>
