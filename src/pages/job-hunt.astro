---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
import JiraColumn from '../components/JiraColumn.astro';
import { getJobs } from '../lib/data';
import { STATUS_COLUMNS, columnOf, withKeys } from '../lib/jobhunt';
import type { ColumnId } from '../lib/jobhunt';
import type { Job } from '../lib/schemas';

const jobs = withKeys(getJobs());

// Bucket by board column, newest application first within each column.
const byColumn = new Map<ColumnId, (Job & { key: number })[]>(STATUS_COLUMNS.map((c) => [c.id, []]));
for (const job of jobs) {
  byColumn.get(columnOf(job.status))!.push(job);
}
for (const list of byColumn.values()) {
  list.sort((a, b) => b.applied.localeCompare(a.applied));
}

const total = jobs.length;
const inFlight = jobs.filter((j) => j.status === 'Applied').length;
const screening = jobs.filter((j) => j.status === 'Screening').length;

// Filter dropdown options, derived from the data.
const companies = [...new Set(jobs.map((j) => j.company))].sort();
const sources = [...new Set(jobs.map((j) => j.source ?? 'Other'))].sort();
const priorities = ['highest', 'high', 'medium', 'low'];

const avatars: { label: string; accent: string }[] = [
  { label: 'TS', accent: 'peach' },
  { label: 'AI', accent: 'lavender' },
  { label: 'KS', accent: 'teal' },
];
---

<Base title="Job Hunt" description="Active job-search pipeline as a JIRA-style kanban board.">
  <section class="border-b border-ctp-surface0 bg-ctp-mantle px-10 pt-6">
    <!-- breadcrumb -->
    <nav class="inline-flex items-center gap-1.5 font-mono text-[12px] text-ctp-overlay1" aria-label="Breadcrumb">
      <span
        class="inline-flex h-[18px] w-[18px] items-center justify-center rounded-[3px] bg-ctp-peach text-[10px] font-bold text-ctp-crust"
        aria-hidden="true">JH</span
      >
      <span>Projects</span>
      <span aria-hidden="true">›</span>
      <span class="text-ctp-subtext1">Job Hunt 2026</span>
      <span aria-hidden="true">›</span>
      <span>boards</span>
      <span aria-hidden="true">›</span>
      <span class="text-ctp-text">Active Pipeline</span>
    </nav>

    <!-- title row -->
    <div class="mt-[18px] flex flex-wrap items-end justify-between gap-8">
      <div>
        <div class="mb-2 flex flex-wrap items-center gap-3">
          <span class="text-[18px] text-ctp-yellow" aria-hidden="true">★</span>
          <h1 class="font-display text-[32px] font-bold tracking-[-0.02em] text-ctp-text">Active Pipeline</h1>
          <span
            class="rounded border border-ctp-surface1 bg-ctp-surface0 px-2.5 py-1 font-mono text-[11px] tracking-[0.04em] text-ctp-subtext0"
          >
            Sprint 4 · 12d remaining
          </span>
        </div>
        <div class="flex flex-wrap items-center gap-4 font-mono text-[12px] text-ctp-subtext0">
          <span>{total} issues</span>
          <span class="text-ctp-overlay1" aria-hidden="true">·</span>
          <span class="text-ctp-blue">● {inFlight} in flight</span>
          <span class="text-ctp-overlay1" aria-hidden="true">·</span>
          <span class="text-ctp-peach">● {screening} screening</span>
          <span class="text-ctp-overlay1" aria-hidden="true">·</span>
          <span>last updated 2h ago by tim</span>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <div class="mr-1 flex" aria-hidden="true">
          {
            avatars.map((a, i) => (
              <span
                class="inline-flex h-7 w-7 items-center justify-center rounded-full border-2 border-ctp-crust font-display text-[11px] font-bold text-ctp-crust"
                class:list={[i > 0 && '-ml-2']}
                style={`background: var(--catppuccin-color-${a.accent})`}
              >
                {a.label}
              </span>
            ))
          }
        </div>
        <Button class="px-3.5 py-2 text-[13px]">Complete sprint</Button>
        <Button variant="ghost" class="px-3 py-2 text-[13px]">ⓘ Insights</Button>
        <Button variant="ghost" class="px-3 py-2 text-[13px]" aria-label="More board actions">⋯</Button>
      </div>
    </div>

    <!-- filter bar -->
    <div class="mt-6 flex flex-wrap items-center gap-2.5 pb-4">
      <label
        class="inline-flex min-w-[240px] flex-1 items-center gap-2 rounded border border-ctp-surface1 bg-ctp-surface0 px-3 py-[7px] font-mono text-[12px] text-ctp-overlay1 sm:max-w-[280px] sm:flex-none"
      >
        <span aria-hidden="true">⌕</span>
        <input
          id="board-search"
          type="search"
          placeholder="Search this board"
          class="w-full bg-transparent text-ctp-text placeholder:text-ctp-overlay1 focus:outline-none"
          aria-label="Search this board"
        />
      </label>

      <div class="relative inline-flex">
        <select
          id="filter-epic"
          aria-label="Filter by company"
          class="cursor-pointer appearance-none rounded border border-ctp-surface1 bg-ctp-mantle py-[7px] pr-8 pl-3 font-mono text-[11.5px] tracking-[0.04em] text-ctp-subtext0 transition-colors hover:border-ctp-overlay0"
        >
          <option value="">EPIC</option>
          {companies.map((c) => <option value={c}>{c}</option>)}
        </select>
        <span
          class="pointer-events-none absolute top-1/2 right-3 -translate-y-1/2 text-[9px] text-ctp-overlay1"
          aria-hidden="true">▾</span
        >
      </div>

      <div class="relative inline-flex">
        <select
          id="filter-priority"
          aria-label="Filter by priority"
          class="cursor-pointer appearance-none rounded border border-ctp-surface1 bg-ctp-mantle py-[7px] pr-8 pl-3 font-mono text-[11.5px] tracking-[0.04em] text-ctp-subtext0 uppercase transition-colors hover:border-ctp-overlay0"
        >
          <option value="">PRIORITY</option>
          {priorities.map((p) => <option value={p}>{p}</option>)}
        </select>
        <span
          class="pointer-events-none absolute top-1/2 right-3 -translate-y-1/2 text-[9px] text-ctp-overlay1"
          aria-hidden="true">▾</span
        >
      </div>

      <div class="relative inline-flex">
        <select
          id="filter-source"
          aria-label="Filter by source"
          class="cursor-pointer appearance-none rounded border border-ctp-surface1 bg-ctp-mantle py-[7px] pr-8 pl-3 font-mono text-[11.5px] tracking-[0.04em] text-ctp-subtext0 transition-colors hover:border-ctp-overlay0"
        >
          <option value="">SOURCE</option>
          {sources.map((s) => <option value={s}>{s}</option>)}
        </select>
        <span
          class="pointer-events-none absolute top-1/2 right-3 -translate-y-1/2 text-[9px] text-ctp-overlay1"
          aria-hidden="true">▾</span
        >
      </div>

      <button
        type="button"
        id="filter-clear"
        hidden
        class="rounded px-3 py-[7px] font-mono text-[11.5px] tracking-[0.04em] text-ctp-overlay1 transition-colors hover:text-ctp-subtext0"
      >
        ✕ clear
      </button>
    </div>
  </section>

  <!-- board: desktop grid · tablet horizontal snap-scroll · mobile accordion -->
  <section
    class="board flex snap-x snap-mandatory gap-3 overflow-x-auto px-10 pt-5 pb-10 md:overflow-x-auto lg:grid lg:snap-none lg:grid-cols-5 lg:items-start lg:overflow-visible"
    aria-label="Job application board"
  >
    {
      STATUS_COLUMNS.map((col) => (
        <div class="board-cell w-[280px] shrink-0 snap-start lg:w-auto lg:shrink" data-board-column={col.id}>
          <JiraColumn label={col.label} accent={col.accent} jobs={byColumn.get(col.id) ?? []} />
        </div>
      ))
    }
  </section>

  {
    /* Read-only board: a drag is a wink, not a mutation. Dropping a card on
      another column snaps it back and surfaces this JIRA-style permission flag
      (bottom-left, one at a time). */
  }
  <div
    data-board-toast
    data-testid="board-toast"
    role="status"
    aria-live="polite"
    class="pointer-events-none fixed bottom-6 left-6 z-[70] flex max-w-[340px] translate-y-3 items-start gap-3 rounded border border-ctp-surface1 bg-ctp-mantle p-3.5 opacity-0 shadow-lg transition-[opacity,transform] duration-200 ease-out data-[show]:translate-y-0 data-[show]:opacity-100"
  >
    <span
      class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-ctp-red text-[12px] font-bold text-ctp-crust"
      aria-hidden="true">!</span
    >
    <span class="font-mono text-[12.5px] leading-snug text-ctp-subtext1">
      You do not have permission to perform this action, contact your site administrator.
    </span>
  </div>
</Base>

<style>
  /* Mobile (<768px): stack columns full-width and collapse each into an
     accordion. The header toggles its body; chevron rotates. */
  @media (max-width: 767px) {
    .board {
      display: flex;
      flex-direction: column;
      overflow: visible;
    }
    .board-cell {
      width: 100%;
    }
    .column-header {
      cursor: pointer;
    }
    .board-column[data-collapsed='true'] .column-body {
      display: none;
    }
    .column-chevron {
      transition: transform 0.15s ease-out;
    }
    .board-column[data-collapsed='true'] .column-chevron {
      transform: rotate(90deg);
    }
  }

  /* Drag affordance — wherever the board is multi-column (>=768px) on a fine
     pointer; below that it's the single-column accordion. The drag ghost itself
     is styled inline in JS (it's appended to <body>, outside this style scope). */
  @media (min-width: 768px) and (pointer: fine) {
    .column-body article {
      cursor: grab;
      touch-action: none;
    }
  }
</style>

<script>
  // Board-filter predicate, "any filter active", and the read-only-drag rule
  // live in lib/jobhunt.ts (unit-tested); this script is the DOM glue.
  import { jobCardMatches, anyJobFilterActive, isIllegalMove } from '../lib/jobhunt';

  // Mobile accordion: collapse all but the first column, toggle on header tap.
  const mq = window.matchMedia('(max-width: 767px)');
  const columns = Array.from(document.querySelectorAll<HTMLElement>('.board-column'));

  function applyAccordion(on: boolean) {
    columns.forEach((col, i) => {
      const header = col.querySelector<HTMLElement>('.column-header');
      if (!header) return;
      if (on) {
        col.dataset.collapsed = i === 0 ? 'false' : 'true';
        header.setAttribute('role', 'button');
        header.setAttribute('tabindex', '0');
        header.setAttribute('aria-expanded', col.dataset.collapsed === 'false' ? 'true' : 'false');
      } else {
        delete col.dataset.collapsed;
        header.removeAttribute('role');
        header.removeAttribute('tabindex');
        header.removeAttribute('aria-expanded');
      }
    });
  }

  function toggle(col: HTMLElement) {
    if (!mq.matches) return;
    const collapsed = col.dataset.collapsed === 'true';
    col.dataset.collapsed = collapsed ? 'false' : 'true';
    col.querySelector('.column-header')?.setAttribute('aria-expanded', collapsed ? 'true' : 'false');
  }

  columns.forEach((col) => {
    const header = col.querySelector<HTMLElement>('.column-header');
    header?.addEventListener('click', () => toggle(col));
    header?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggle(col);
      }
    });
  });

  applyAccordion(mq.matches);
  mq.addEventListener('change', (e) => applyAccordion(e.matches));

  // Board filters: search (role/company) + epic (company) + priority + source.
  const search = document.getElementById('board-search') as HTMLInputElement | null;
  const epicSel = document.getElementById('filter-epic') as HTMLSelectElement | null;
  const prioSel = document.getElementById('filter-priority') as HTMLSelectElement | null;
  const srcSel = document.getElementById('filter-source') as HTMLSelectElement | null;
  const clearBtn = document.getElementById('filter-clear') as HTMLButtonElement | null;
  const cards = Array.from(document.querySelectorAll<HTMLElement>('article[data-search]'));
  const boardCols = Array.from(document.querySelectorAll<HTMLElement>('.board-column'));

  // Subtle cross-fade when filters change, via the View Transitions API. Used
  // for the dropdowns + clear (not the live search input, which fires per
  // keystroke). No-ops to an instant apply under reduced-motion / no support.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const doc = document as Document & { startViewTransition?: (cb: () => void) => void };
  const withTransition = (fn: () => void) => {
    if (reduceMotion.matches || !doc.startViewTransition) fn();
    else doc.startViewTransition(fn);
  };

  function applyFilters() {
    const criteria = {
      q: (search?.value ?? '').trim().toLowerCase(),
      epic: epicSel?.value ?? '',
      prio: prioSel?.value ?? '',
      source: srcSel?.value ?? '',
    };
    for (const card of cards) {
      const d = card.dataset;
      const show = jobCardMatches(
        { search: d.search ?? '', company: d.company ?? '', priority: d.priority ?? '', source: d.source ?? '' },
        criteria
      );
      card.classList.toggle('hidden', !show);
    }
    for (const col of boardCols) {
      const visible = col.querySelectorAll('article[data-search]:not(.hidden)').length;
      const countEl = col.querySelector('[data-count]');
      if (countEl) countEl.textContent = String(visible);
      const empty = col.querySelector<HTMLElement>('[data-empty]');
      if (empty) empty.hidden = visible > 0;
    }
    if (clearBtn) clearBtn.hidden = !anyJobFilterActive(criteria);
  }

  search?.addEventListener('input', applyFilters);
  [epicSel, prioSel, srcSel].forEach((s) => s?.addEventListener('change', () => withTransition(applyFilters)));
  clearBtn?.addEventListener('click', () => {
    if (search) search.value = '';
    for (const s of [epicSel, prioSel, srcSel]) if (s) s.value = '';
    withTransition(applyFilters);
  });

  // Read-only board drag (#90): cards lift on desktop, but any attempt to move
  // one to another column snaps it back and flashes a single JIRA-style
  // permission toast. No data changes — the board re-renders from jobs.yml.
  // Enabled wherever the board is multi-column (>=768px). Below that it
  // collapses to a single-column accordion (max-width: 767px) and drag is off.
  // Touch is excluded via the pointerType check below, so width is the gate.
  const deskDrag = window.matchMedia('(min-width: 768px)');
  const toast = document.querySelector<HTMLElement>('[data-board-toast]');
  let toastTimer: ReturnType<typeof setTimeout> | undefined;
  function flashToast() {
    if (!toast) return;
    const t = toast; // one reused element — re-triggering resets it, never stacks
    t.dataset.show = 'true';
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => {
      delete t.dataset.show;
    }, 2600);
  }

  function columnUnder(x: number, y: number): string | null {
    const el = document.elementFromPoint(x, y);
    return el?.closest<HTMLElement>('[data-board-column]')?.dataset.boardColumn ?? null;
  }

  for (const card of cards) {
    card.addEventListener('pointerdown', (e) => {
      if (!deskDrag.matches || e.button !== 0 || e.pointerType === 'touch') return;
      const from = card.dataset.column ?? '';
      const rect = card.getBoundingClientRect();
      const startX = e.clientX;
      const startY = e.clientY;
      const offX = startX - rect.left;
      const offY = startY - rect.top;
      let ghost: HTMLElement | null = null;
      const at = (x: number, y: number) => `translate(${Math.round(x - offX)}px, ${Math.round(y - offY)}px)`;

      const onMove = (ev: PointerEvent) => {
        if (!ghost) {
          // Small threshold so a click/select isn't treated as a drag.
          if (Math.hypot(ev.clientX - startX, ev.clientY - startY) < 6) return;
          ghost = card.cloneNode(true) as HTMLElement;
          ghost.setAttribute('data-drag-ghost', '');
          // Styles set inline (not via the scoped <style>) because the ghost is
          // appended to <body>, outside this component's style scope. Crucially
          // pointer-events:none keeps it out of elementFromPoint at drop time.
          Object.assign(ghost.style, {
            position: 'fixed',
            left: '0',
            top: '0',
            margin: '0',
            width: `${rect.width}px`,
            zIndex: '60',
            pointerEvents: 'none',
            boxShadow: '0 12px 28px rgba(0, 0, 0, 0.45)',
            opacity: '0.96',
            transform: at(ev.clientX, ev.clientY),
          });
          document.body.appendChild(ghost);
          card.style.opacity = '0.4';
          document.body.style.cursor = 'grabbing';
        } else {
          ghost.style.transform = `${at(ev.clientX, ev.clientY)} rotate(2deg)`;
        }
      };

      const finish = () => {
        card.removeEventListener('pointermove', onMove);
        card.removeEventListener('pointerup', onUp);
        card.removeEventListener('pointercancel', onUp);
        document.body.style.cursor = '';
      };

      const onUp = (ev: PointerEvent) => {
        finish();
        if (!ghost) return; // never crossed the threshold — it was a click
        const g = ghost;
        if (isIllegalMove(from, columnUnder(ev.clientX, ev.clientY))) flashToast();

        const cleanup = () => {
          g.remove();
          card.style.opacity = '';
        };
        if (reduceMotion.matches) {
          cleanup();
        } else {
          // Snap the clone back to the (unmoved) card, then drop it.
          const back = card.getBoundingClientRect();
          g.style.transition = 'transform 180ms ease-out';
          g.style.transform = at(back.left + offX, back.top + offY);
          g.addEventListener('transitionend', cleanup, { once: true });
          setTimeout(cleanup, 280); // fallback if transitionend is missed
        }
      };

      card.setPointerCapture(e.pointerId);
      card.addEventListener('pointermove', onMove);
      card.addEventListener('pointerup', onUp);
      card.addEventListener('pointercancel', onUp);
    });
  }
</script>
