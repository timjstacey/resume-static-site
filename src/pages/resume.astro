---
import Base from '../layouts/Base.astro';
import ResumeSection from '../components/ResumeSection.astro';
import { getResume } from '../lib/data';
import { Image } from 'astro:assets';
import profilePhoto from '../assets/profile.jpg';

const resume = getResume();

function fmtYM(ym: string): string {
  const [year, month] = ym.split('-');
  return new Date(Number(year), Number(month) - 1).toLocaleDateString('en-GB', {
    month: 'short',
    year: 'numeric',
  });
}
---

<Base title="Resume">
  <header class="mb-2 flex items-start gap-6">
    <Image
      src={profilePhoto}
      alt={resume.name}
      width={96}
      height={96}
      class="rounded-full object-cover ring-2 ring-ctp-surface1"
    />
    <div>
      <h1 class="text-4xl font-bold text-ctp-text">{resume.name}</h1>
      <p class="mt-1 text-lg text-ctp-subtext1">{resume.tagline}</p>
      <div class="mt-3 flex flex-wrap gap-4 text-ctp-blue">
        {
          resume.contact.github && (
            <a
              href={resume.contact.github}
              class="flex items-center gap-1.5 hover:text-ctp-text"
              target="_blank"
              rel="noopener"
              aria-label="GitHub"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
              </svg>
              <span class="text-sm">GitHub</span>
            </a>
          )
        }
        {
          resume.contact.linkedin && (
            <a
              href={resume.contact.linkedin}
              class="flex items-center gap-1.5 hover:text-ctp-text"
              target="_blank"
              rel="noopener"
              aria-label="LinkedIn"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              <span class="text-sm">LinkedIn</span>
            </a>
          )
        }
      </div>
    </div>
  </header>

  <ResumeSection title="Experience">
    <div class="space-y-6">
      {
        resume.experience.map((exp) => (
          <div>
            <div class="flex flex-wrap items-baseline justify-between gap-x-4">
              <span class="font-bold text-ctp-text">{exp.company}</span>
              <span class="text-sm text-ctp-subtext0">
                {fmtYM(exp.start)} &ndash; {exp.end === 'present' ? 'Present' : fmtYM(exp.end)}
              </span>
            </div>
            <p class="text-ctp-subtext1">{exp.role}</p>
            <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-ctp-text">
              {exp.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </ResumeSection>

  <ResumeSection title="Skills">
    <div class="space-y-4">
      {
        resume.skills.map((group) => (
          <div>
            <span class="text-sm font-semibold text-ctp-subtext1">{group.category}</span>
            <div class="mt-2 flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="rounded-full bg-ctp-surface1 px-3 py-1 text-xs text-ctp-text">{item}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </ResumeSection>
</Base>

<style>
  @media print {
    :global(nav),
    :global(footer) {
      display: none !important;
    }
    :global(main) {
      padding: 0 !important;
      max-width: 100% !important;
    }
  }
</style>
