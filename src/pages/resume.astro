---
import Base from '../layouts/Base.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Button from '../components/Button.astro';
import { getResume } from '../lib/data';
import { fmtYM } from '../lib/format';

const resume = getResume();

// Derive display slug for company (e.g. "Sony Interactive Entertainment" → "sony-interactive-entertainment")
function companySlug(name: string) {
  return name
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

// Build period string from start/end
function period(start: string, end: string | 'present') {
  const s = fmtYM(start);
  const e = end === 'present' ? 'Present' : fmtYM(end);
  return `${s} – ${e}`;
}

// Prettify contact URL to display text
function displayContact(url: string) {
  return url.replace(/^https?:\/\/(www\.)?/, '');
}

// Zero-pad past role index (1-based, skipping current)
function padIndex(n: number) {
  return String(n).padStart(2, '0');
}
---

<Base title="Resume" description="Tim Stacey — Lead Quality Engineer resume">
  <!-- ========== PAGE HEADER ========== -->
  <header class="border-b border-ctp-surface0 px-14 py-14">
    <div class="grid items-end gap-14 md:grid-cols-[1.5fr_1fr]">
      <!-- Left: section label + big heading -->
      <div>
        <SectionLabel>// resume.tex</SectionLabel>
        <h1
          class="mt-5 font-display text-5xl leading-[0.95] font-bold tracking-[-0.035em] text-ctp-text md:text-[88px]"
          data-testid="resume-heading"
        >
          10 years of<br />
          <span style="color: var(--catppuccin-color-peach)">not breaking prod.</span>
        </h1>
      </div>

      <!-- Right: meta rows + buttons -->
      <div class="flex flex-col gap-2.5 font-mono text-[12.5px] text-ctp-subtext1">
        <!-- status -->
        <div class="flex gap-3">
          <span class="w-16 shrink-0 text-ctp-overlay2">status</span>
          <span class="text-ctp-subtext0">:</span>
          <span style="color: var(--catppuccin-color-green)">● open · from 2026-06-15</span>
        </div>
        <!-- email (not in data — use contact fields we have) -->
        {
          resume.contact.github && (
            <div class="flex gap-3">
              <span class="w-16 shrink-0 text-ctp-overlay2">github</span>
              <span class="text-ctp-subtext0">:</span>
              <a
                href={resume.contact.github}
                target="_blank"
                rel="noopener"
                class="text-ctp-text transition-colors hover:text-ctp-peach"
              >
                {displayContact(resume.contact.github)}
              </a>
            </div>
          )
        }
        {
          resume.contact.linkedin && (
            <div class="flex gap-3">
              <span class="w-16 shrink-0 text-ctp-overlay2">linkedin</span>
              <span class="text-ctp-subtext0">:</span>
              <a
                href={resume.contact.linkedin}
                target="_blank"
                rel="noopener"
                class="text-ctp-text transition-colors hover:text-ctp-peach"
              >
                {displayContact(resume.contact.linkedin)}
              </a>
            </div>
          )
        }
        <!-- based -->
        <div class="flex gap-3">
          <span class="w-16 shrink-0 text-ctp-overlay2">based</span>
          <span class="text-ctp-subtext0">:</span>
          <span class="text-ctp-text">remote · au</span>
        </div>

        <!-- Action buttons -->
        <div class="mt-3 flex gap-2">
          <Button
            variant="primary"
            href="/tim-stacey-resume.pdf"
            download="tim-stacey-resume.pdf"
            class="flex-1 justify-center"
          >
            ⬇ download.pdf
          </Button>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== BODY ========== -->
  <div class="px-14 pt-14 pb-20">
    <div class="flex flex-col gap-14 md:grid md:grid-cols-[300px_1fr] md:gap-14" style="gap: 56px">
      <!-- ===== SIDEBAR ===== -->
      <aside class="flex flex-col gap-8" data-testid="resume-sidebar">
        <!-- Skills groups -->
        {
          resume.skills.map((group) => (
            <div aria-label={group.category}>
              <div class="mb-3 flex items-center justify-between border-b border-ctp-surface0 pb-2 font-mono text-[11px] tracking-[0.12em] text-ctp-overlay2 uppercase">
                <span>{group.category}</span>
                <span class="text-ctp-overlay0">{group.items.length}</span>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {group.items.map((item) => (
                  <span class="rounded border border-ctp-surface0 bg-ctp-mantle px-2 py-1 font-mono text-[11.5px] text-ctp-subtext1">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))
        }

        <!-- Education (optional) -->
        {
          resume.education && resume.education.length > 0 && (
            <div>
              <div class="mb-3 border-b border-ctp-surface0 pb-2 font-mono text-[11px] tracking-[0.12em] text-ctp-overlay2 uppercase">
                Education
              </div>
              <div class="flex flex-col gap-3">
                {resume.education.map((ed) => (
                  <div class="text-[13px] leading-relaxed">
                    <div class="font-semibold text-ctp-text">{ed.degree}</div>
                    <div class="text-ctp-subtext1">{ed.institution}</div>
                    <div class="mt-0.5 font-mono text-[11.5px] text-ctp-overlay1">{ed.year}</div>
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </aside>

      <!-- ===== MAIN: EXPERIENCE ===== -->
      <main>
        <SectionLabel>experience · 2015 — 2026</SectionLabel>

        <div class="mt-8 flex flex-col gap-5">
          {
            (() => {
              let pastCount = 0;
              return resume.experience.map((exp) => {
                const isCurrent = exp.end === 'present';
                const cardIndex = isCurrent ? null : ++pastCount;
                const slug = companySlug(exp.company);
                const periodStr = period(exp.start, exp.end);

                return (
                  <article
                    aria-label={exp.company}
                    class="rounded-lg p-7"
                    style={
                      isCurrent
                        ? `background: var(--catppuccin-color-mantle); border: 1px solid color-mix(in srgb, var(--catppuccin-color-peach) 33%, transparent); border-left: 4px solid var(--catppuccin-color-peach);`
                        : `background: var(--catppuccin-color-crust); border: 1px solid var(--catppuccin-color-surface0); border-left: 4px solid var(--catppuccin-color-surface1);`
                    }
                  >
                    <div class="mb-4 flex flex-col gap-2 md:flex-row md:items-start md:justify-between md:gap-6">
                      <div class="min-w-0">
                        <div
                          class="mb-2 font-mono text-[11px] tracking-[0.1em] uppercase"
                          style={
                            isCurrent
                              ? 'color: var(--catppuccin-color-peach)'
                              : 'color: var(--catppuccin-color-overlay2)'
                          }
                        >
                          {isCurrent ? '● current role' : padIndex(cardIndex!)}
                        </div>
                        <h2 class="font-display text-2xl leading-tight font-bold tracking-[-0.02em] break-words text-ctp-text md:text-[28px]">
                          {exp.role}
                        </h2>
                        <div class="mt-1 font-mono text-sm" style="color: var(--catppuccin-color-teal)">
                          @ {slug}
                        </div>
                      </div>
                      <div class="shrink-0 font-mono text-[12px] text-ctp-subtext0 md:text-right">
                        <div class="text-ctp-text">{periodStr}</div>
                      </div>
                    </div>

                    {exp.bullets.length > 0 && (
                      <ul class="flex flex-col gap-2 p-0" style="list-style: none; margin: 0">
                        {exp.bullets.map((bullet) => (
                          <li
                            class="flex gap-3 text-[14.5px] leading-[1.55] text-ctp-subtext1"
                            style="text-wrap: pretty"
                          >
                            <span class="mt-px shrink-0 font-mono" style="color: var(--catppuccin-color-peach)">
                              →
                            </span>
                            <span>{bullet}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </article>
                );
              });
            })()
          }
        </div>
      </main>
    </div>
  </div>
</Base>

<style>
  @media print {
    :global(nav),
    :global(footer) {
      display: none !important;
    }
    :global(.mx-auto) {
      max-width: 100% !important;
    }
  }
</style>
