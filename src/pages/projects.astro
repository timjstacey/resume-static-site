---
import Base from '../layouts/Base.astro';
import SectionLabel from '../components/SectionLabel.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getProjects } from '../lib/data';
import { PROJECT_FILTERS } from '../lib/projectFilters';

const projects = getProjects();
const totalStars = projects.reduce((s, p) => s + (p.stars ?? 0), 0);
const pinnedCount = projects.filter((p) => p.pinned).length;

const filters = PROJECT_FILTERS;
---

<Base title="Projects" description="Open-source and side projects by Tim Stacey">
  <!-- HEADER -->
  <header class="border-b border-ctp-surface0 px-5 pt-14 pb-12 sm:px-14">
    <div class="grid items-end gap-10 md:grid-cols-[1.5fr_1fr]">
      <div>
        <SectionLabel>// projects.yml</SectionLabel>
        <h1 class="mt-5 font-display text-5xl leading-[0.95] font-bold tracking-[-0.035em] text-ctp-text md:text-7xl">
          <span class="text-ctp-peach">$</span>
          <span class="text-ctp-teal">cat</span> projects.yml
        </h1>
      </div>
      <dl class="grid grid-cols-3 divide-x divide-ctp-surface0 border-y border-ctp-surface0">
        <div class="px-4 py-3">
          <dd data-testid="stat-repos" class="font-display text-4xl font-bold text-ctp-text">{projects.length}</dd>
          <dt class="mt-1 mono-caption text-ctp-overlay2">repos</dt>
        </div>
        <div class="px-4 py-3">
          <dd data-total-stars class="stat-skeleton font-display text-4xl font-bold text-ctp-text">{totalStars}</dd>
          <dt class="mt-1 mono-caption text-ctp-overlay2">stars</dt>
        </div>
        <div class="px-4 py-3">
          <dd class="font-display text-4xl font-bold text-ctp-text">{pinnedCount}</dd>
          <dt class="mt-1 mono-caption text-ctp-overlay2">pinned</dt>
        </div>
      </dl>
    </div>
  </header>

  <!-- FILTER BAR -->
  <div class="flex flex-wrap items-center justify-between gap-4 border-b border-ctp-surface0 px-5 py-8 sm:px-14">
    <!-- Mobile: a single select keeps the row tidy and aligned with the sort control.
         Custom chevron (appearance-none + ▾ span) mirrors the job-hunt selects. -->
    <div class="relative inline-flex sm:hidden">
      <select
        data-filter-select
        aria-label="Filter projects"
        class="cursor-pointer appearance-none rounded border border-ctp-surface2 bg-ctp-base py-1 pr-8 pl-2.5 font-mono text-[12px] text-ctp-subtext0 transition-colors hover:text-ctp-text"
      >
        {filters.map((f) => <option value={f}>{f}</option>)}
      </select>
      <span
        class="pointer-events-none absolute top-1/2 right-2.5 -translate-y-1/2 text-[9px] text-ctp-overlay1"
        aria-hidden="true">▾</span
      >
    </div>
    <!-- sm+: inline chip buttons. -->
    <div class="hidden flex-wrap items-center gap-2 sm:flex">
      <span class="mr-1 mono-caption text-ctp-overlay2">filter:</span>
      {
        filters.map((f) => (
          <button
            type="button"
            data-filter={f}
            class="rounded px-2.5 py-1 font-mono text-[12px] text-ctp-subtext0 transition-colors hover:text-ctp-text data-[active]:bg-ctp-peach data-[active]:text-ctp-crust"
          >
            {f === 'all' ? '● all' : f}
          </button>
        ))
      }
    </div>
    <button
      type="button"
      id="sort-btn"
      class="rounded border border-ctp-surface2 px-2.5 py-1 font-mono text-[12px] text-ctp-subtext0 transition-colors hover:text-ctp-text"
    >
      sort: updated <span id="sort-arrow" data-testid="sort-arrow">↓</span>
    </button>
  </div>

  <!-- GRID -->
  <section class="px-5 pt-8 pb-4 sm:px-14">
    <div id="project-grid" class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <p id="empty-state" class="hidden py-12 text-center font-mono text-sm text-ctp-overlay1">─ no projects match ─</p>
  </section>
</Base>

<script>
  import '../scripts/projects';
</script>
