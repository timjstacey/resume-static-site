---
import { Code } from 'astro-expressive-code/components';
import Base from '../layouts/Base.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import StatStrip from '../components/StatStrip.astro';
import StatCard from '../components/StatCard.astro';
import { getTesting, getCiSnapshot } from '../lib/data';
import { stepDuration } from '../lib/ciGates';
import { TEST_STATS } from '../lib/testStats';

const repoUrl = 'https://github.com/timjstacey/resume-static-site';
const { routing, workflows } = getTesting();
const ci = getCiSnapshot();

const cleanRuns = ci.runs.filter((r) => r === 'pass').length;
const runColor = (r: string) => (r === 'pass' ? 'green' : r === 'flake' ? 'yellow' : 'red');
const engineColor = (e: string) => (e === 'chromium' ? 'yellow' : e === 'firefox' ? 'peach' : 'sapphire');

const maxSpecs = Math.max(TEST_STATS.unit, TEST_STATS.e2e);
// Routing saving: routed runs vs the naive "every spec on every project" total.
const dedupPct = TEST_STATS.e2eNaive ? Math.round((1 - TEST_STATS.e2e / TEST_STATS.e2eNaive) * 100) : 0;

// Real run durations from CI (same `gates` source as the gate cards): the
// vitest layer = the coverage-gate test step, playwright = the E2E run step.
// Null (old snapshot) → the layer just omits the duration suffix.
const layers = [
  {
    name: 'vitest',
    accent: 'green',
    count: TEST_STATS.unit,
    caption: 'cheap checks',
    // wf/step feed both the build-time stepDuration() and the client re-resolve
    // against fresh ci.gates after hydration.
    wf: 'ci.yml',
    step: 'Test (with coverage gate)',
    dur: stepDuration(ci.gates, 'ci.yml', 'Test (with coverage gate)'),
    scope: ['schema validation', 'pure helpers', 'data loaders', 'nav + format logic'],
  },
  {
    name: 'playwright',
    accent: 'sapphire',
    count: TEST_STATS.e2e,
    caption: 'rendered surface',
    wf: 'playwright.yml',
    step: 'Run pnpm exec playwright test',
    dur: stepDuration(ci.gates, 'playwright.yml', 'Run pnpm exec playwright test'),
    scope: ['page content per route', 'keyboard + focus a11y', 'responsive layout', 'theme switching'],
  },
];

const flow = [
  { src: 'resume.yml', loader: 'getResume()', spec: 'resume.spec.ts' },
  { src: 'jobs.yml', loader: 'getJobs()', spec: 'jobs.spec.ts' },
  { src: 'projects.yml', loader: 'getProjects()', spec: 'projects.spec.ts' },
];

// Short illustrative example of the data-driven spec pattern.
const sampleSpec = `import { getJobs } from '../src/lib/data';
import { withKeys } from '../src/lib/jobhunt';

const jobs = withKeys(getJobs());

for (const job of jobs) {
  test(job.company, async ({ page }) => {
    await page.goto('/job-hunt');
    await expect(card(job)).toBeVisible();
  });
}
`;
---

<Base title="Testing" description="How this site tests itself: CI, the test pyramid, and project routing.">
  <!-- HEADER -->
  <header class="grid gap-10 px-5 pt-14 sm:px-14 lg:grid-cols-[1.4fr_1fr]">
    <div>
      <SectionLabel>// testing.md</SectionLabel>
      <h1 class="mt-5 font-display text-5xl leading-[0.98] font-bold tracking-[-0.035em] text-ctp-text md:text-[80px]">
        This page is its
        <span class="text-ctp-peach">own</span>
        <span class="text-ctp-teal">test report.</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ctp-subtext1">
        Every number below comes from the same data and CI signals the site ships with. Nothing here is mocked.
      </p>
    </div>
    <dl class="flex flex-col gap-2.5 self-end font-mono text-[12.5px]">
      {
        [
          ['repo', 'timjstacey/resume-static-site'],
          ['stack', 'astro · tailwind · catppuccin'],
          ['runner', 'vitest + playwright'],
          ['policy', 'green gates every merge'],
        ].map(([k, v]) => (
          <div class="flex gap-3">
            <dt class="w-[64px] shrink-0 text-ctp-overlay2">{k}</dt>
            <dd class="text-ctp-text">{v}</dd>
          </div>
        ))
      }
    </dl>
  </header>

  <!-- CI STATUS STRIP -->
  <section class="px-5 pt-10 sm:px-14">
    <div
      class="rounded-lg border border-ctp-surface0 bg-ctp-mantle px-6 py-5"
      style="border-left: 4px solid var(--catppuccin-color-green)"
    >
      <div class="grid gap-8 md:grid-cols-4">
        <div>
          <div class="mono-caption text-ctp-overlay2">branch</div>
          <div class="mt-2 flex items-center gap-2 font-mono text-sm text-ctp-text">
            <span class="h-2 w-2 rounded-full bg-ctp-green"></span><span data-ci-branch>{ci.branch}</span>
            <span
              data-ci-passing
              class="stat-skeleton rounded bg-ctp-peach px-1.5 py-0.5 text-[10px] font-semibold text-ctp-crust uppercase"
            >
              {ci.passing ? 'passing' : 'failing'}
            </span>
          </div>
        </div>
        <div class="min-w-0">
          <div class="mono-caption text-ctp-overlay2">
            latest commit · <span data-ci-commitago>{ci.commitAgo}</span>
          </div>
          <div class="mt-2 flex min-w-0 items-center gap-2 font-mono text-[13px]">
            <span
              data-ci-sha
              class="stat-skeleton shrink-0 rounded px-1.5 py-0.5 text-ctp-sapphire"
              style="background: color-mix(in srgb, var(--catppuccin-color-sapphire) 18%, transparent)">#{ci.sha}</span
            >
            <span data-ci-message class="stat-skeleton min-w-0 truncate text-ctp-subtext1">{ci.commitMessage}</span>
          </div>
        </div>
        <div>
          <div class="mono-caption text-ctp-overlay2">last 10 runs</div>
          <div class="mt-2 flex items-center gap-1.5">
            <span data-ci-runs class="stat-skeleton flex items-center gap-1.5">
              {
                ci.runs.map((r) => (
                  <span
                    class="h-3.5 w-3.5 rounded-[3px]"
                    style={`background: var(--catppuccin-color-${runColor(r)})`}
                  />
                ))
              }
            </span>
            <span class="ml-2 font-mono text-[12px] text-ctp-subtext0"
              ><span data-ci-clean>{cleanRuns}</span>/10 clean</span
            >
          </div>
        </div>
        <div>
          <div class="mono-caption text-ctp-overlay2">p50 · p95</div>
          <div class="mt-2 font-mono text-[13px] text-ctp-text">
            <span data-ci-p50 class="stat-skeleton">{ci.p50}</span>
            <span class="text-ctp-green">▾ <span data-ci-p50delta>{ci.p50Delta}</span></span>
          </div>
          <div class="font-mono text-[13px] text-ctp-text">
            <span data-ci-p95 class="stat-skeleton">{ci.p95}</span>
            <span class="text-ctp-yellow">▴ <span data-ci-p95delta>{ci.p95Delta}</span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <StatStrip class="mt-5">
    <StatCard index="01" value={TEST_STATS.unit} label="unit specs" accent="green" />
    <StatCard index="02" value={TEST_STATS.e2e} label="E2E flows" accent="sapphire" />
    <StatCard index="03" value={TEST_STATS.projects} label="playwright projects" accent="peach" />
    <StatCard index="04" value={TEST_STATS.engines} label="browser engines" accent="mauve" />
  </StatStrip>

  <!-- TWO-LAYER PYRAMID -->
  <section class="px-5 pt-16 sm:px-14">
    <div class="flex items-end justify-between">
      <div>
        <SectionLabel color="green">// two-layer pyramid</SectionLabel>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-[-0.025em] text-ctp-text">
          Cheap where we can. Browser where we must.
        </h2>
      </div>
      <p class="hidden max-w-xs text-right font-mono text-[11px] text-ctp-overlay1 md:block">
        yes, this site leans heavy on E2E<br />it is mostly UI
      </p>
    </div>

    <Card class="mt-8 p-6">
      <div class="flex items-center justify-between font-mono text-[11px] text-ctp-overlay2">
        <span class="tracking-[0.1em] uppercase">spec counts · relative</span>
        <span>{TEST_STATS.unit + TEST_STATS.e2e} specs total</span>
      </div>
      <div class="mt-5 flex flex-col gap-4">
        {
          layers.map((l) => (
            <div>
              <div class="flex items-baseline justify-between">
                <span class="font-display text-base font-bold" style={`color: var(--catppuccin-color-${l.accent})`}>
                  {l.name} <span class="font-mono text-[12px] font-normal text-ctp-overlay1">· {l.caption}</span>
                </span>
                <span class="font-mono text-[12px] text-ctp-subtext0">
                  {l.count} specs
                  <span data-layer-dur data-gate-wf={l.wf} data-gate-step={l.step}>
                    {l.dur ? ` · ${l.dur}` : ''}
                  </span>
                </span>
              </div>
              <div class="mt-1.5 h-[18px] w-full rounded bg-ctp-surface0">
                <div
                  class="h-full rounded"
                  style={`width:${(l.count / maxSpecs) * 100}%; background: var(--catppuccin-color-${l.accent})`}
                />
              </div>
            </div>
          ))
        }
      </div>
    </Card>

    <div class="mt-4 grid gap-4 md:grid-cols-2">
      {
        layers.map((l) => (
          <Card accent={l.accent} accentWidth={3} class="p-6">
            <div class="flex items-baseline justify-between">
              <span class="font-display text-lg font-bold text-ctp-text">{l.name}</span>
              <span class="font-mono text-[12px] text-ctp-overlay1">{l.count} specs</span>
            </div>
            <ul class="mt-4 flex flex-col gap-2">
              {l.scope.map((s) => (
                <li class="flex gap-2.5 text-[14px] text-ctp-subtext1">
                  <span style={`color: var(--catppuccin-color-${l.accent})`}>→</span>
                  {s}
                </li>
              ))}
            </ul>
          </Card>
        ))
      }
    </div>
  </section>

  <!-- PROJECT ROUTING -->
  <section class="px-5 pt-16 sm:px-14">
    <div class="flex items-end justify-between">
      <div>
        <SectionLabel color="sapphire">// project routing</SectionLabel>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-[-0.025em] text-ctp-text">
          Split by spec type. Skip the duplicates.
        </h2>
      </div>
      <p class="hidden font-mono text-[11px] text-ctp-overlay1 md:block">
        {routing.length} playwright projects · {TEST_STATS.engines} engines
      </p>
    </div>

    <div
      class="mt-8 flex flex-wrap items-center gap-6 rounded-lg border border-ctp-surface0 bg-ctp-mantle p-6"
      style="border-left: 4px solid var(--catppuccin-color-peach)"
    >
      <div class="flex flex-col gap-1 md:flex-row md:items-center md:gap-3">
        <div class="flex items-center gap-3">
          <span class="font-display text-[42px] font-bold text-ctp-overlay1 line-through">{TEST_STATS.e2eNaive}</span>
          <span class="text-ctp-overlay1">→</span>
          <span class="font-display text-[56px] font-bold text-ctp-peach">{TEST_STATS.e2e}</span>
        </div>
        <span class="font-mono text-[12px] text-ctp-overlay1">runs · -{dedupPct}%</span>
      </div>
      <p class="flex-1 text-center text-[14px] text-ctp-subtext1">
        Content renders identically across engines, so it runs once. Only keyboard, focus, and viewport behaviour fan
        out across browsers.
      </p>
    </div>

    <div class="mt-4 hidden overflow-x-auto md:block" data-testid="routing-matrix">
      <div
        class="grid grid-cols-[2fr_1fr_1fr_3fr] gap-px overflow-hidden rounded-lg border border-ctp-surface0 bg-ctp-surface0 font-mono text-[12px]"
      >
        <div class="bg-ctp-surface0 px-4 py-2 text-ctp-overlay2 uppercase">project</div>
        <div class="bg-ctp-surface0 px-4 py-2 text-ctp-overlay2 uppercase">device</div>
        <div class="bg-ctp-surface0 px-4 py-2 text-ctp-overlay2 uppercase">engine</div>
        <div class="bg-ctp-surface0 px-4 py-2 text-ctp-overlay2 uppercase">specs</div>
        {
          routing.map((r) => (
            <>
              <div class="bg-ctp-mantle px-4 py-3 text-ctp-text">{r.project}</div>
              <div class="bg-ctp-mantle px-4 py-3 text-ctp-subtext1">{r.device}</div>
              <div class="bg-ctp-mantle px-4 py-3">
                <span
                  class="rounded px-1.5 py-0.5"
                  style={`color: var(--catppuccin-color-${engineColor(r.engine)}); background: color-mix(in srgb, var(--catppuccin-color-${engineColor(r.engine)}) 20%, transparent)`}
                >
                  {r.engine}
                </span>
              </div>
              <div class="flex flex-wrap gap-1.5 bg-ctp-mantle px-4 py-3">
                {r.specs.map((s) => (
                  <span class="rounded bg-ctp-surface0 px-1.5 py-0.5 text-[11px] text-ctp-subtext1">{s}</span>
                ))}
              </div>
            </>
          ))
        }
      </div>
    </div>

    <!-- Mobile: stacked cards (the grid above is awkward to scroll horizontally). -->
    <div class="mt-4 flex flex-col gap-3 md:hidden">
      {
        routing.map((r) => (
          <div class="rounded-lg border border-ctp-surface0 bg-ctp-mantle p-4 font-mono text-[12px]">
            <div class="text-[13px] text-ctp-text">{r.project}</div>
            <dl class="mt-3 grid grid-cols-[64px_1fr] gap-y-2 text-[12px]">
              <dt class="text-ctp-overlay2 uppercase">device</dt>
              <dd class="text-ctp-subtext1">{r.device}</dd>
              <dt class="text-ctp-overlay2 uppercase">engine</dt>
              <dd>
                <span
                  class="rounded px-1.5 py-0.5"
                  style={`color: var(--catppuccin-color-${engineColor(r.engine)}); background: color-mix(in srgb, var(--catppuccin-color-${engineColor(r.engine)}) 20%, transparent)`}
                >
                  {r.engine}
                </span>
              </dd>
              <dt class="text-ctp-overlay2 uppercase">specs</dt>
              <dd class="flex flex-wrap gap-1.5">
                {r.specs.map((s) => (
                  <span class="rounded bg-ctp-surface0 px-1.5 py-0.5 text-[11px] text-ctp-subtext1">{s}</span>
                ))}
              </dd>
            </dl>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CI GATES -->
  <section class="px-5 pt-16 sm:px-14">
    <SectionLabel>// ci gates</SectionLabel>
    <h2 class="mt-4 font-display text-4xl font-bold tracking-[-0.025em] text-ctp-text">
      Two pipelines. Two minutes between green and merged.
    </h2>
    <div class="mt-8 flex flex-col gap-4">
      {
        workflows.map((wf) => (
          <Card class="p-6">
            <div class="flex flex-col gap-1 font-mono text-[12px] md:flex-row md:items-center md:justify-between md:gap-3">
              <span class="text-ctp-text" style={`color: var(--catppuccin-color-${wf.accent})`}>
                {wf.file}
              </span>
              <span class="text-ctp-overlay1">on: {wf.on}</span>
            </div>
            <div class="mt-4 flex flex-wrap items-stretch gap-2">
              {wf.steps.map((step, i) => {
                const dur = stepDuration(ci.gates, wf.file, step.match);
                return (
                  <>
                    <div
                      class="min-w-[140px] flex-1 rounded p-3"
                      style={`border-top: 2px solid var(--catppuccin-color-${wf.accent}); background: var(--catppuccin-color-base)`}
                    >
                      <div class="mono-caption text-ctp-overlay1">step {i + 1}</div>
                      <div class="mt-1 font-mono text-[13px] text-ctp-text">{step.name}</div>
                      <div
                        data-gate-dur
                        data-gate-wf={wf.file}
                        data-gate-step={step.match}
                        class:list={['mt-1 font-mono text-[12px]', dur ? 'text-ctp-green' : 'text-ctp-overlay1']}
                      >
                        {dur ? `✓ ${dur}` : '— no data'}
                      </div>
                    </div>
                    {i < wf.steps.length - 1 && (
                      <span class="hidden self-center text-lg text-ctp-overlay1 md:inline">→</span>
                    )}
                  </>
                );
              })}
            </div>
          </Card>
        ))
      }
    </div>
  </section>

  <!-- DATA-DRIVEN -->
  <section class="px-5 pt-16 sm:px-14">
    <SectionLabel color="teal">// data-driven everything</SectionLabel>
    <h2 class="mt-4 font-display text-4xl font-bold tracking-[-0.025em] text-ctp-text">
      One YAML. The site renders it. The tests assert against it.
    </h2>
    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <Card class="p-6">
        <div class="flex flex-col gap-3 font-mono text-[12px]">
          {
            flow.map((f) => (
              <div class="flex flex-col gap-1 md:grid md:grid-cols-3 md:gap-2">
                <span class="rounded bg-ctp-surface0 px-2 py-1.5 text-ctp-peach">{f.src}</span>
                <span class="rounded bg-ctp-surface0 px-2 py-1.5 text-ctp-teal">
                  <span class="text-ctp-overlay1">→ </span>
                  {f.loader}
                </span>
                <span class="rounded bg-ctp-surface0 px-2 py-1.5 text-ctp-sapphire">
                  <span class="text-ctp-overlay1">→ </span>
                  {f.spec}
                </span>
              </div>
            ))
          }
        </div>
        <div class="mt-4 border-t border-dashed border-ctp-surface1 pt-3 font-mono text-[11px] text-ctp-overlay1">
          loaders live in src/lib/, imported by both components and specs.
        </div>
      </Card>
      <TerminalWindow path="jobs.spec.ts" meta="UTF-8 · typescript">
        <div class="code-window">
          <Code code={sampleSpec} lang="ts" frame="none" />
        </div>
      </TerminalWindow>
    </div>
  </section>

  <!-- SOURCE CTA -->
  <section class="px-5 pt-14 pb-4 sm:px-14">
    <Card class="flex flex-wrap items-center justify-between gap-4 p-7">
      <div>
        <div class="mono-caption text-ctp-overlay2">// source</div>
        <p class="mt-2 font-display text-[22px] font-bold text-ctp-text">Everything on this page is in the repo.</p>
      </div>
      <Button variant="primary" href={repoUrl}>timjstacey/resume-static-site →</Button>
    </Card>
  </section>
</Base>

<style>
  /* Strip Expressive Code's own frame chrome so the highlighted code sits flush in the
     terminal body (the TerminalWindow already supplies the window). frame="none" drops
     the editor frame; these reset the residual background/padding. */
  .code-window :global(.expressive-code),
  .code-window :global(.expressive-code .frame),
  .code-window :global(.expressive-code pre) {
    background: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
    margin: 0 !important;
  }
  .code-window :global(.expressive-code pre) {
    padding: 0 !important;
    font-size: 13px;
    line-height: 1.7;
    overflow-x: auto;
  }
</style>

<script>
  import '../scripts/testing-ci';
</script>
