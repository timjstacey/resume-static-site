---
import Base from '../layouts/Base.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Button from '../components/Button.astro';
import Chip from '../components/Chip.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import { getPosts } from '../lib/posts';
import { hashtagCounts, archive } from '../lib/blog';

const posts = await getPosts();
const featured = posts[0];
const rest = posts.slice(1);

const postLikes = posts.map((p) => ({ tag: p.data.tag, date: p.data.date }));
const tags = hashtagCounts(posts.map((p) => ({ hashtags: p.data.hashtags })));
const years = archive(postLikes);

const TAG_ACCENT: Record<string, string> = {
  Strategy: 'peach',
  Practice: 'teal',
  Meta: 'mauve',
  Team: 'sapphire',
  Tools: 'yellow',
};
const tagAccent = (tag: string): string => TAG_ACCENT[tag] ?? 'lavender';

// Hashtags have no fixed colour; assign a stable accent per name from a palette.
const HASHTAG_PALETTE = [
  'peach',
  'teal',
  'mauve',
  'sapphire',
  'yellow',
  'green',
  'blue',
  'pink',
  'lavender',
  'flamingo',
];
const hashtagAccent = (tag: string): string =>
  HASHTAG_PALETTE[[...tag].reduce((sum, c) => sum + c.charCodeAt(0), 0) % HASHTAG_PALETTE.length]!;

const fmtDate = (d: Date) => d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
const prefixColor = (p: string) => (p === '$' ? 'text-ctp-peach' : p === '#' ? 'text-ctp-teal' : 'text-ctp-subtext1');
const pad = (n: number) => String(n).padStart(3, '0');
---

<Base title="Blog" description="Field notes on testing and quality engineering by Tim Stacey">
  <!-- HEADER -->
  <header class="grid gap-10 px-5 pt-14 sm:px-14 lg:grid-cols-[1.4fr_1fr]">
    <div>
      <SectionLabel color="teal">// blog.md</SectionLabel>
      <h1 class="mt-5 font-display text-5xl leading-[0.98] font-bold tracking-[-0.035em] text-ctp-text md:text-[80px]">
        <span class="text-ctp-text">Field notes from someone who</span>
        <span class="text-ctp-peach">tests</span>
        <span class="text-ctp-overlay1">for a </span>
        <span class="text-ctp-teal">living.</span>
      </h1>
    </div>
    <dl class="flex flex-col gap-2.5 self-end font-mono text-[12.5px]">
      {
        [
          ['published', String(posts.length)],
          ['cadence', 'when it matters'],
          ['written in', 'markdown + vim'],
        ].map(([k, v]) => (
          <div class="flex gap-3">
            <dt class="w-[88px] shrink-0 text-ctp-overlay2">{k}</dt>
            <dd class="text-ctp-text">{v}</dd>
          </div>
        ))
      }
    </dl>
  </header>

  <!-- FEATURED -->
  {
    featured && (
      <section class="px-5 pt-14 sm:px-14" data-post data-hashtags={featured.data.hashtags.join(' ')}>
        <div
          class="relative overflow-hidden rounded-lg border border-ctp-surface0 bg-ctp-mantle p-8"
          style="background: radial-gradient(ellipse 700px 380px at 20% 30%, color-mix(in srgb, var(--catppuccin-color-peach) 8%, transparent), transparent 70%), var(--catppuccin-color-mantle)"
        >
          <span class="absolute top-6 right-6 flex items-center gap-2 font-mono text-[11px] text-ctp-green">
            <span class="h-2 w-2 rounded-full bg-ctp-green" />
            featured · latest
          </span>
          <div class="grid gap-14 lg:grid-cols-[1.1fr_1fr]">
            <div>
              <SectionLabel color={tagAccent(featured.data.tag)}>// post {pad(posts.length)}</SectionLabel>
              <h2 class="mt-5 font-display text-4xl leading-[1.02] font-bold tracking-[-0.03em] text-balance text-ctp-text md:text-[56px]">
                {featured.data.title}
              </h2>
              <p class="mt-5 text-lg leading-relaxed text-ctp-subtext1">{featured.data.excerpt}</p>
              <div class="mt-5 flex items-center gap-4 font-mono text-[12px] text-ctp-overlay1">
                <span>{fmtDate(featured.data.date)}</span>
                <span>~{featured.data.readMins}min</span>
                <Chip color={tagAccent(featured.data.tag)}>{featured.data.tag}</Chip>
              </div>
              {featured.data.hashtags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {featured.data.hashtags.map((h) => (
                    <span class="font-mono text-[11px]" style={`color: var(--catppuccin-color-${hashtagAccent(h)})`}>
                      #{h}
                    </span>
                  ))}
                </div>
              )}
              <div class="mt-7 flex flex-wrap gap-3">
                <Button variant="primary" href={`/blog/${featured.id}`}>
                  ▸ cat posts/{featured.id}.md
                </Button>
                <Button
                  variant="ghost"
                  data-copy-link
                  data-path={`/blog/${featured.id}`}
                  class="min-w-[9rem] justify-center"
                >
                  ⎘ copy link
                </Button>
              </div>
            </div>
            <TerminalWindow path={`cat ${featured.id}.md`} class="lg:mt-8">
              {featured.data.preview.map(([prefix, text], i) => (
                <div class="flex gap-3.5">
                  <span class={`w-2 shrink-0 ${prefixColor(prefix)}`}>{prefix.trim()}</span>
                  <span class="text-ctp-subtext1">
                    {text}
                    {i === featured.data.preview.length - 1 && <span class="terminal-cursor ml-0.5" />}
                  </span>
                </div>
              ))}
            </TerminalWindow>
          </div>
        </div>
      </section>
    )
  }

  <!-- PUBLISHED + SIDEBAR -->
  <section class="grid gap-14 px-5 pt-18 sm:px-14 lg:grid-cols-[1fr_280px]">
    <div>
      <div class="flex items-center justify-between border-b border-ctp-surface0 pb-3">
        <SectionLabel>// published</SectionLabel>
        <span class="font-mono text-[11px] text-ctp-overlay1">{posts.length} posts · newest first</span>
      </div>
      <div>
        {
          rest.map((post, i) => (
            <a
              href={`/blog/${post.id}`}
              data-testid="published-row"
              data-post
              data-hashtags={post.data.hashtags.join(' ')}
              class="flex gap-3 border-b border-ctp-surface0 py-5 transition-colors hover:bg-ctp-mantle sm:grid sm:grid-cols-[60px_6px_1fr_auto] sm:items-center sm:gap-4"
            >
              <span class="hidden font-mono text-[13px] text-ctp-overlay1 sm:block">{pad(rest.length - i)}</span>
              <span
                class="w-1.5 shrink-0 self-stretch rounded-full sm:h-14 sm:self-auto"
                style={`background: var(--catppuccin-color-${tagAccent(post.data.tag)})`}
              />
              <span class="min-w-0 flex-1">
                <span class="flex flex-wrap items-center gap-x-3 gap-y-1">
                  <span class="font-display text-lg font-semibold tracking-[-0.01em] text-ctp-text sm:text-xl">
                    {post.data.title}
                  </span>
                  <Chip color={tagAccent(post.data.tag)}>{post.data.tag}</Chip>
                </span>
                <span class="mt-1 block text-[14.5px] text-ctp-subtext0">{post.data.excerpt}</span>
                <span class="mt-2 flex items-center gap-3 font-mono text-[12px] text-ctp-overlay1 sm:hidden">
                  <span>{fmtDate(post.data.date)}</span>
                  <span>~{post.data.readMins}min</span>
                  <span class="text-ctp-peach">read →</span>
                </span>
              </span>
              <span class="hidden text-right font-mono text-[12px] text-ctp-overlay1 sm:block">
                <span class="block">{fmtDate(post.data.date)}</span>
                <span class="block">~{post.data.readMins}min</span>
                <span class="block text-ctp-peach">read →</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <aside class="flex flex-col gap-8">
      <div>
        <div class="mb-3 border-b border-ctp-surface0 pb-2 mono-caption text-ctp-overlay2">
          Tags · {tags.length}
        </div>
        <div class="flex flex-col gap-1" data-tag-filters>
          {
            tags.map((t) => (
              <button
                type="button"
                data-tag-filter={t.tag}
                aria-pressed="false"
                class="tag-filter flex items-center gap-2 rounded px-1.5 py-1 font-mono text-[12px] transition-colors hover:bg-ctp-surface0"
              >
                <span
                  class="h-3 w-3 rounded-[2px]"
                  style={`background: var(--catppuccin-color-${hashtagAccent(t.tag)})`}
                />
                <span class="text-ctp-subtext1">#{t.tag}</span>
                <span class="ml-auto text-ctp-overlay1">×{t.count}</span>
              </button>
            ))
          }
        </div>
      </div>

      <div>
        {
          years.map((y) => (
            <div>
              <div class="mb-2 flex items-center justify-between border-b border-ctp-surface0 pb-2 font-mono text-[12px]">
                <span class="text-ctp-text">{y.year}</span>
                <span class="text-ctp-peach">{y.count} posts</span>
              </div>
              <div class="flex flex-col gap-1.5">
                {y.months.map((m) => (
                  <div class="flex items-center gap-2 font-mono text-[12px] text-ctp-subtext0">
                    <span class="text-ctp-overlay1">─</span>
                    {m.month} · {m.count}
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <div>
        <div class="mb-3 border-b border-ctp-surface0 pb-2 mono-caption text-ctp-overlay2">Subscribe</div>
        <div class="flex gap-2">
          {
            [
              ['RSS', '/rss.xml'],
              ['Atom', '/atom.xml'],
              ['JSON Feed', '/feed.json'],
            ].map(([label, href]) => (
              <a
                href={href}
                class="rounded border border-ctp-surface2 px-2.5 py-1 font-mono text-[11px] text-ctp-subtext0 transition-colors hover:border-ctp-overlay0 hover:text-ctp-text"
              >
                {label}
              </a>
            ))
          }
        </div>
      </div>
    </aside>
  </section>
</Base>

<script>
  // Featured "copy link" — copies the post's absolute URL to the clipboard.
  document.querySelector('[data-copy-link]')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLElement;
    const path = btn.getAttribute('data-path') ?? location.pathname;
    try {
      await navigator.clipboard.writeText(new URL(path, location.origin).href);
      const original = btn.textContent;
      btn.textContent = '✓ copied';
      setTimeout(() => {
        if (original !== null) btn.textContent = original;
      }, 1500);
    } catch {
      /* clipboard unavailable */
    }
  });

  // Tag filter — click a sidebar tag to show only posts carrying that hashtag;
  // click the active tag again to clear. Pure show/hide, no navigation.
  (() => {
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tag-filter]'));
    if (buttons.length === 0) return;
    const posts = Array.from(document.querySelectorAll<HTMLElement>('[data-post]'));
    let active: string | null = null;

    const apply = () => {
      for (const post of posts) {
        const tags = (post.getAttribute('data-hashtags') ?? '').split(/\s+/).filter(Boolean);
        post.hidden = active !== null && !tags.includes(active);
      }
      for (const btn of buttons) {
        btn.setAttribute('aria-pressed', String(btn.dataset.tagFilter === active));
      }
    };

    for (const btn of buttons) {
      btn.addEventListener('click', () => {
        active = active === btn.dataset.tagFilter ? null : (btn.dataset.tagFilter ?? null);
        apply();
      });
    }
  })();
</script>

<style>
  .tag-filter[aria-pressed='true'] {
    background: color-mix(in srgb, var(--catppuccin-color-peach) 14%, transparent);
  }
  .tag-filter[aria-pressed='true'] span:nth-child(2) {
    color: var(--catppuccin-color-text);
  }
</style>
