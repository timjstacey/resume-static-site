---
import Nav from '../components/Nav.astro';
import ThemePicker from '../components/ThemePicker.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Tim Stacey — software engineer' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (function () {
        const valid = ['latte', 'frappe', 'macchiato', 'mocha'];
        let stored;
        try {
          stored = localStorage.getItem('ctp-flavor');
        } catch {}
        const flavor = valid.includes(stored)
          ? stored
          : window.matchMedia('(prefers-color-scheme: light)').matches
            ? 'latte'
            : 'mocha';
        document.documentElement.classList.add(flavor);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | Tim Stacey</title>
  </head>
  <body class="min-h-screen bg-ctp-base text-ctp-text">
    <Nav>
      <ThemePicker />
    </Nav>
    <main class="mx-auto max-w-4xl px-4 py-8">
      <slot />
    </main>
    <footer class="border-t border-ctp-surface1 py-4 text-center text-sm text-ctp-subtext0">
      <p>Built with Astro + Tailwind + Catppuccin</p>
    </footer>
  </body>
</html>
