{
  "name": "resume-static-site",
  "version": "1.25.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview --port 4322",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "stats:refresh": "node scripts/refresh-test-stats.mjs",
    "ci:refresh": "node scripts/refresh-ci-snapshot.mjs",
    "projects:refresh": "node scripts/refresh-project-stats.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@catppuccin/tailwindcss": "1.0.0",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "@tailwindcss/vite": "4.3.0",
    "astro": "6.3.5",
    "astro-expressive-code": "^0.42.0",
    "rehype-external-links": "^3.0.0",
    "tailwindcss": "4.3.0",
    "yaml": "^2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "10.4.0",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-playwright": "^2.10.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "sharp": "0.34.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{astro,ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{css,json,md,yaml,yml}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
