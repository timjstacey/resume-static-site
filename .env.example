# Umami Cloud website id. When set at build time, Base.astro injects the
# cookieless tracking script. Leave unset locally; set it only on the
# Cloudflare Pages *Production* environment so preview/dev don't report.
UMAMI_WEBSITE_ID=your-website-id-here
# UMAMI_SRC defaults to the US cloud host (https://cloud.umami.is/script.js).
# Uncomment for the EU region:
# UMAMI_SRC=https://eu.umami.is/script.js
